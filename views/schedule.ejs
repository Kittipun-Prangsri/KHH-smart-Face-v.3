// ============ WEEK NAV ============
function prevWeek() { currentWeekOffset--; renderCalendar(); }
function nextWeek() { currentWeekOffset++; renderCalendar(); }
function goToday()  { currentWeekOffset=0; renderCalendar(); }

function jumpToSpecificDate(dateStr) {
  if (!dateStr) return;
  const target = new Date(dateStr);
  const today = new Date();
  
  // Set to midnight for clean comparison
  target.setHours(0,0,0,0);
  today.setHours(0,0,0,0);
  
  // Find Monday of the current week (today's week)
  const todayDow = today.getDay();
  const currentMonday = new Date(today);
  currentMonday.setDate(today.getDate() - (todayDow === 0 ? 6 : todayDow - 1));
  
  // Find Monday of the target week (selected date's week)
  const targetDow = target.getDay();
  const targetMonday = new Date(target);
  targetMonday.setDate(target.getDate() - (targetDow === 0 ? 6 : targetDow - 1));
  
  // Diff in weeks
  const diffMs = targetMonday.getTime() - currentMonday.getTime();
  const diffWeeks = Math.round(diffMs / (1000 * 60 * 60 * 24 * 7));
  
  currentWeekOffset = diffWeeks;
  renderCalendar();
}

