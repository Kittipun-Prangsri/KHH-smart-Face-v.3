// ============ DATA FROM API ============
async function loadEmployees() {
  try {
    const res = await fetch('/api/personnel');
    const dbData = await res.json();
    const personnelList = dbData.personnel || dbData || [];
    
    // Also fetch saved shift schedule assignments
    let scheduleRes = await fetch('/api/schedule').catch(()=>null);
    let scheduleData = [];
    if (scheduleRes && scheduleRes.ok) {
      scheduleData = await scheduleRes.json();
    }
    
    employees = personnelList.flatMap((p, idx) => {
      const pAssignments = scheduleData.filter(s => s.emp_id === p.FINGLE_ID || s.emp_id === p.ID);
      
      if (pAssignments.length === 0) {
          return [{
            id: p.ID || idx + 1,
            real_id: p.FINGLE_ID || p.ID,
            name: p.HR_FNAME ? `${p.HR_FNAME} ${p.HR_LNAME}` : (p.Name || 'ไม่ระบุชื่อ'),
            no: p.FINGLE_ID || p.EmployeeNo || '-',
            team: p.HR_DEPARTMENT_NAME || p.Department || 'ไม่ระบุแผนก',
            shift: 'EMPTY',
            date: '',
            email: p.HR_EMAIL || ((p.FINGLE_ID||'emp') + '@khh.co.th'),
            phone: p.HR_PHONE || p.Phone || '-'
          }];
      }

      return pAssignments.map(assigned => ({
        id: p.ID || idx + 1,
        real_id: p.FINGLE_ID || p.ID,
        name: p.HR_FNAME ? `${p.HR_FNAME} ${p.HR_LNAME}` : (p.Name || 'ไม่ระบุชื่อ'),
        no: p.FINGLE_ID || p.EmployeeNo || '-',
        team: p.HR_DEPARTMENT_NAME || p.Department || 'ไม่ระบุแผนก',
        shift: assigned.shift,
        date: assigned.date || '',
        email: p.HR_EMAIL || ((p.FINGLE_ID||'emp') + '@khh.co.th'),
        phone: p.HR_PHONE || p.Phone || '-'
      }));
    });
    
    renderCalendar();
    if (document.getElementById('tab-team').style.display !== 'none') renderTeam();
    updateStats();
  } catch (err) {
    console.error('Error fetching personnel', err);
    showToast('❌ ไม่สามารถดึงข้อมูลบุคลากรได้');
  }
}

