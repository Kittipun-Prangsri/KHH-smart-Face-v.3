// ============ TOAST ============
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 3000);
}

// ============ INIT ============

// ============ DATA FROM API ============
async function loadEmployees() {
  try {
    const res = await fetch('/api/personnel');
    const dbData = await res.json();
    const personnelList = dbData.personnel || dbData || [];
    
    // Also fetch saved shift schedule assignments
    let scheduleRes = await fetch('/api/schedule').catch(()=>null);
    let scheduleData = [];
    if (scheduleRes && scheduleRes.ok) {
      scheduleData = await scheduleRes.json();
    }
    
    employees = personnelList.map((p, idx) => {
      const assigned = scheduleData.find(s => s.emp_id === p.FINGLE_ID || s.emp_id === p.ID);
      return {
        id: p.ID || idx + 1,
        real_id: p.FINGLE_ID || p.ID, // for DB linking
        name: p.HR_FNAME ? `${p.HR_FNAME} ${p.HR_LNAME}` : (p.Name || 'ไม่ระบุชื่อ'),
        no: p.FINGLE_ID || p.EmployeeNo || '-',
        team: p.HR_DEPARTMENT_NAME || p.Department || 'ไม่ระบุแผนก',
        shift: assigned ? assigned.shift : 'EMPTY',
        email: p.HR_EMAIL || ((p.FINGLE_ID||'emp') + '@khh.co.th'),
        phone: p.HR_PHONE || p.Phone || '-'
      };
    });
    
    renderCalendar();
    if (document.getElementById('tab-team').style.display !== 'none') renderTeam();
    updateStats();
  } catch (err) {
    console.error('Error fetching personnel', err);
    showToast('❌ ไม่สามารถดึงข้อมูลบุคลากรได้');
  }
}

// override tag function for EMPTY
function getShiftTagCustom(shiftType) {
  const map = { MORNING:'tag-morning', AFTERNOON:'tag-afternoon', NIGHT:'tag-night', EMPTY:'tag-empty' };
  const label = { MORNING:'เช้า', AFTERNOON:'บ่าย', NIGHT:'ดึก', EMPTY:'ว่าง' };
  return `<span class="tag ${map[shiftType]||'tag-empty'}">${label[shiftType]||'ว่าง'}</span>`;
}
getShiftTag = getShiftTagCustom; // Override existing getShiftTag

loadEmployees();
updateNotifBadge(); // Initial badge count
