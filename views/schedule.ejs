async function saveEmployee() {
  const name = document.getElementById('f-name').value.trim();
  if (!name) { showToast('⚠️ กรุณากรอกชื่อพนักงาน'); return; }
  
  const emp_id = document.getElementById('f-no').value;
  const shift = document.getElementById('f-shift').value;
  const date = document.getElementById('f-date').value;

  if (!date) { showToast('⚠️ กรุณาเลือกวันที่'); return; }
  
  // Save to backend
  try {
    const res = await fetch('/api/schedule', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ emp_id, shift, date })
    });
    if (res.ok) {
        showToast('✅ บันทึกข้อมูล ' + name + ' เรียบร้อยแล้ว');
        addNotification('success', editId ? 'อัปเดตข้อมูลพนักงาน' : 'เพิ่มพนักงานใหม่', `พนักงาน ${name} ถูกบันทึกลงในตารางเวรเรียบร้อยแล้ว`);
        await loadEmployees(); // Refresh data from backend
    }
  } catch (err) {
    console.error(err);
    showToast('⚠️ ไม่สามารถบันทึกลงฐานข้อมูลได้');
  }
  
  closeModalDirect();
}

async function deleteEmployee() {
  if (!editId) return;
  const name = document.getElementById('f-name').value;
  const emp_id = document.getElementById('f-no').value;
  const date = document.getElementById('f-date').value;

  if (confirm('คุณต้องการลบพนักงานคนนี้ออกจากตารางเวรใช่หรือไม่?')) {
    // Remote delete backend
    try {
      const res = await fetch('/api/schedule', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ emp_id, shift: 'EMPTY', date }) // Reset to empty for date acts as deleting
      });
      if (res.ok) {
          showToast('🗑 ลบข้อมูลเรียบร้อยแล้ว');
          addNotification('alert', 'ลบข้อมูลพนักงาน', `พนักงาน ${name} ถูกลบออกจากตารางเวรแล้ว`);
          await loadEmployees();
      }
    } catch (err) {}
    
    closeModalDirect();
  }
}

function exportExcel() {
  const currentTabId = ['calendar', 'team', 'notify', 'daily-report'].find(t => document.getElementById('tab-' + t).style.display !== 'none');
  const title = document.getElementById('topbar-title').innerText;
  const fileName = (title || 'export') + '.xlsx';

  showToast('📊 กำลังส่งออกข้อมูลเป็น Excel...');

  if (currentTabId === 'daily-report') {
    // Manually build rows to exclude Department (2nd column)
    const headers = ['ชื่อ-นามสกุล', 'สถานะ', 'เวลาเข้า', 'เวลาออก', 'รวมเวลา'];
    const tableBody = document.getElementById('daily-report-body');
    const rows = Array.from(tableBody.querySelectorAll('tr')).map(tr => {
      const tds = tr.querySelectorAll('td');
      return [
        tds[0].innerText, // Name
        tds[2].innerText, // Status
        tds[3].innerText, // In
        tds[4].innerText, // Out
        tds[5].innerText  // Hours
      ];
    });
    const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "DailyReport");
    XLSX.writeFile(wb, fileName);
  } else if (currentTabId === 'team') {
    // Build array from employees data - Exclude team
    const headers = ['รหัสพนักงาน', 'ชื่อ-นามสกุล', 'เบอร์โทรศัพท์', 'อีเมล'];
    const rows = employees.map(e => [e.no, e.name, e.phone, e.email]);
    const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "PersonnelList");
    XLSX.writeFile(wb, fileName);
  } else if (currentTabId === 'calendar') {
    // Custom Weekly Grid export
    const dates = getWeekDates(currentWeekOffset);
    const dateHeaders = ['Shift / Date', ...dates.map(d => d.toLocaleDateString('th-TH', {day:'2-digit', month:'2-digit'}))];
    
    // Create rows for each shift
    const rows = SHIFTS.map(shift => {
      const row = [shift.label];
      dates.forEach(date => {
        const dateStr = date.toISOString().split('T')[0];
        const assigned = employees.filter(e => e.date === dateStr && e.shift === shift.type);
        row.push(assigned.map(e => e.name).join(', '));
      });
      return row;
    });

    const ws = XLSX.utils.aoa_to_sheet([dateHeaders, ...rows]);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "WeeklySchedule");
    XLSX.writeFile(wb, fileName);
  } else if (currentTabId === 'monthly-report') {
    const table = document.querySelector('#monthly-report-body').parentElement;
    if (table) {
      const wb = XLSX.utils.table_to_book(table);
      XLSX.writeFile(wb, fileName);
    }
  } else {
    showToast('⚠️ หน้าปัจจุบันไม่รองรับการส่งออก Excel');
  }
}
