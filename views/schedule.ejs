<script>
  const userRole = '<%= locals.user ? user.role : "user" %>';
// ============ DATA ============
const SHIFTS = [
  { id:1, type:'MORNING',   label:'กะเช้า',  time:'06:00-14:00', color:'#D97706',  dot:'#F59E0B' },
  { id:2, type:'AFTERNOON', label:'กะบ่าย', time:'16:00-00:00', color:'#1D4ED8', dot:'#2563EB' },
  { id:3, type:'NIGHT',     label:'กะดึก',   time:'00:00-08:00', color:'#6D28D9', dot:'#7C3AED' },
];

const DAYS_TH = ['อา.','จ.','อ.','พ.','พฤ.','ศ.','ส.'];
const MONTHS_TH = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน',
  'กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];

const AVATAR_COLORS = [
  {bg:'rgba(79,124,255,.18)',color:'#6e9fff'},
  {bg:'rgba(255,179,71,.18)',color:'#ffb347'},
  {bg:'rgba(79,195,247,.18)',color:'#4fc3f7'},
  {bg:'rgba(155,142,247,.18)',color:'#9b8ef7'},
  {bg:'rgba(61,214,140,.18)',color:'#3dd68c'},
  {bg:'rgba(255,95,95,.18)',color:'#ff5f5f'},
];

let employees = [];

let nextId = 10;
let currentWeekOffset = 0;

const NOTIFICATIONS = [
  { id:1, type:'swap',  title:'คำขอสลับเวร', desc:'สมชาย ใจดี ขอสลับเวรกับ วิภา รักงาน (25 มี.ค.)', time:'5 นาทีที่แล้ว',  read:false, icon:'🔄' },
  { id:2, type:'alert', title:'พนักงานขาดเวร', desc:'กาญจนา แก้ว ยังไม่ยืนยันเวรวันพุธ',          time:'1 ชั่วโมงที่แล้ว', read:false, icon:'⚠️' },
  { id:3, type:'auto',  title:'สลับเวรอัตโนมัติ', desc:'ระบบจัดตารางเวรสัปดาห์ถัดไปเรียบร้อยแล้ว', time:'เมื่อวาน',           read:false, icon:'✅' },
  { id:4, type:'info',  title:'Export สำเร็จ', desc:'ดาวน์โหลดตารางเวรเดือนมีนาคม (.xlsx)',         time:'2 วันที่แล้ว',       read:true,  icon:'📊' },
];

// ============ HELPERS ============
function getWeekDates(offset=0) {
  const today = new Date();
  const dow = today.getDay();
  const monday = new Date(today);
  monday.setDate(today.getDate() - dow + 1 + offset*7);
  return Array.from({length:7}, (_,i) => {
    const d = new Date(monday);
    d.setDate(monday.getDate()+i);
    return d;
  });
}

function getInitials(name) {
  const parts = name.split(' ');
  return parts.length >= 2 ? (parts[0][0]+parts[1][0]) : name.substring(0,2);
}

function getAvatarStyle(id) {
  const c = AVATAR_COLORS[(id-1) % AVATAR_COLORS.length];
  return `background:${c.bg};color:${c.color}`;
}

function getShiftTag(shiftType) {
  const map = { MORNING:'tag-morning', AFTERNOON:'tag-afternoon', NIGHT:'tag-night' };
  const label = { MORNING:'เช้า', AFTERNOON:'บ่าย', NIGHT:'ดึก' };
  return `<span class="tag ${map[shiftType]||''}">${label[shiftType]||shiftType}</span>`;
}

function isToday(date) {
  const t = new Date();
  return date.getDate()===t.getDate() && date.getMonth()===t.getMonth() && date.getFullYear()===t.getFullYear();
}

// ============ RENDER CALENDAR ============
function renderCalendar() {
  const dates = getWeekDates(currentWeekOffset);
  const month = MONTHS_TH[dates[0].getMonth()];
  const year = dates[0].getFullYear() + 543;
  document.getElementById('cal-title').textContent = `${month} ${year}`;

  // Assign employees to shifts for each day (round-robin)
  const empByShift = {
    MORNING:   employees.filter(e=>e.shift==='MORNING'),
    AFTERNOON: employees.filter(e=>e.shift==='AFTERNOON'),
    NIGHT:     employees.filter(e=>e.shift==='NIGHT'),
  };

  let html = `<div class="week-header">
    <div class="week-header-cell"></div>`;
  dates.forEach((d,i) => {
    const tod = isToday(d);
    html += `<div class="week-header-cell${tod?' today':''}">
      ${DAYS_TH[i===6?0:i+1]}<br>
      <span style="font-size:14px;font-weight:${tod?600:400};color:${tod?'var(--accent)':'var(--text)'}">${d.getDate()}</span>
    </div>`;
  });
  html += '</div>';

  SHIFTS.forEach(shift => {
    const emps = empByShift[shift.type] || [];
    html += `<div class="shift-row">
      <div class="shift-label" style="color:${shift.color}">
        <span class="shift-dot" style="background:${shift.dot}"></span>
        <span>${shift.label}<br><span style="font-size:10px;color:var(--text3);font-family:var(--mono)">${shift.time}</span></span>
      </div>`;

    dates.forEach((date,dayIdx) => {
      html += `<div class="shift-cell">`;
      // Specific assignments for this date and shift
      const dateStr = date.toISOString().split('T')[0];
      const assigned = employees.filter(e => e.date === dateStr && e.shift === shift.type);
      
      assigned.forEach((emp) => {
        html += `<div class="emp-chip" title="${emp.name} · ${emp.team}" onclick="showEmpDetail(${emp.id}, '${dateStr}')">
          <span class="avatar" style="${getAvatarStyle(emp.id)}">${getInitials(emp.name)}</span>
          <span style="color:var(--text2)">${emp.name.split(' ')[0]}</span>
        </div>`;
      });
      html += `<div class="add-slot" onclick="openAddSlot('${dateStr}')" title="เพิ่มพนักงาน">+</div>`;
      html += `</div>`;
    });

    html += `</div>`;
  });

  document.getElementById('week-grid').innerHTML = html;
  updateStats();
}

function updateStats() {
  document.getElementById('stat-total').textContent = employees.length;
  document.getElementById('stat-morning').textContent = employees.filter(e=>e.shift==='MORNING').length;
  document.getElementById('stat-afternoon').textContent = employees.filter(e=>e.shift==='AFTERNOON').length;
  document.getElementById('stat-night').textContent = employees.filter(e=>e.shift==='NIGHT').length;
}

// ============ RENDER TEAM ============
function renderTeam() {
  const html = employees.map(emp => {
    const shiftHours = emp.shift==='MORNING'||emp.shift==='AFTERNOON' ? 8 : 8;
    return `<div class="emp-card" onclick="showEmpDetail(${emp.id})">
      <div class="emp-header">
        <div class="emp-avatar" style="${getAvatarStyle(emp.id)}">${getInitials(emp.name)}</div>
        <div>
          <div class="emp-name">${emp.name}</div>
          <div class="emp-no">${emp.no}</div>
        </div>
      </div>
      <div class="emp-meta">
        <span class="tag tag-team">${emp.team}</span>
        ${getShiftTag(emp.shift)}
        <span class="tag" style="color:var(--text2);border-color:var(--border)">${emp.phone}</span>
      </div>
      <div class="emp-stats">
        <div class="mini-stat"><strong>40</strong>ชม./สัปดาห์</div>
        <div class="mini-stat"><strong>5</strong>วัน/สัปดาห์</div>
        <div class="mini-stat"><strong>${emp.email.split('@')[0]}</strong>อีเมล</div>
      </div>
    </div>`;
  }).join('');
  document.getElementById('team-grid').innerHTML = html;
}

// ============ RENDER NOTIFICATIONS ============
function renderNotifications() {
  const html = NOTIFICATIONS.map(n => `
    <div class="notif-item" onclick="markRead(${n.id})" style="${n.read?'opacity:.6; cursor:default':'cursor:pointer'}">
      <div class="notif-icon" style="background:var(--bg4)">${n.icon}</div>
      <div class="notif-body">
        <div class="notif-title">${n.title}${!n.read?'<span style="display:inline-block;width:6px;height:6px;background:var(--accent);border-radius:50%;margin-left:8px;vertical-align:middle"></span>':''}</div>
        <div class="notif-desc">${n.desc}</div>
      </div>
      <div class="notif-time">${n.time}</div>
    </div>`).join('');
  document.getElementById('notif-list').innerHTML = html;
  updateNotifBadge();
}

function updateNotifBadge() {
  const unread = NOTIFICATIONS.filter(n => !n.read).length;
  const badge = document.getElementById('notif-badge');
  badge.textContent = unread;
  badge.style.display = unread > 0 ? 'inline-block' : 'none';
}

function markRead(id) {
  const n = NOTIFICATIONS.find(x => x.id === id);
  if (n) {
    n.read = true;
    renderNotifications();
  }
}

function markAllRead() {
  NOTIFICATIONS.forEach(n => n.read = true);
  renderNotifications();
  showToast('✅ อ่านการแจ้งเตือนทั้งหมดแล้ว');
}

function addNotification(type, title, desc) {
  const icons = { info: 'ℹ️', success: '✅', alert: '⚠️', swap: '🔄' };
  NOTIFICATIONS.unshift({
    id: Date.now(),
    type,
    title,
    desc,
    time: 'เมื่อครู่',
    read: false,
    icon: icons[type] || '🔔'
  });
  renderNotifications();
}

// ============ TABS ============
function showTab(tab) {
  const actions = document.getElementById('topbar-actions-panel');
  if (actions) actions.style.display = tab === 'calendar' ? 'flex' : 'none';

  const tabList = ['calendar', 'team', 'notify', 'daily-report', 'monthly-report'];
  tabList.forEach(t => {
    const el = document.getElementById('tab-' + t);
    if (!el) return;
    el.style.display = t === tab ? 'block' : 'none';
    el.classList.remove('fade-in');
    if (t === tab) setTimeout(() => el.classList.add('fade-in'), 10);
  });

  // Sidebar highlights
  document.querySelectorAll('.sidebar-nav .nav-item').forEach(n => n.classList.remove('active'));
  const titles = {
    calendar: 'ตารางเวรประจำสัปดาห์',
    team: 'รายชื่อพนักงานทั้งหมด',
    notify: 'การแจ้งเตือน',
    'daily-report': 'รายงานการเข้างานรายวัน',
    'monthly-report': 'รายงานสรุปรายเดือน (สถิติพนักงานจัดเวร)'
  };
  const titleEl = document.getElementById('topbar-title');
  if (titleEl) titleEl.textContent = titles[tab] || '';

  // Better highlight logic using index or data-tab (if added)
  // For now let's find the nav-item that has the showTab call
  document.querySelectorAll('.sidebar-nav .nav-item').forEach(item => {
    const clickAttr = item.getAttribute('onclick') || '';
    if (clickAttr.includes(`showTab('${tab}')`)) {
      item.classList.add('active');
    }
  });

  if (tab === 'team') renderTeam();
  if (tab === 'notify') renderNotifications();
  if (tab === 'daily-report') fetchDailyReportData();
  if (tab === 'monthly-report') fetchMonthlyReportData();
}

async function fetchMonthlyReportData() {
    const month = document.getElementById('monthly-month-input').value;
    const year = document.getElementById('monthly-year-input').value;
    const body = document.getElementById('monthly-report-body');
    const empty = document.getElementById('monthly-report-empty');
    
    body.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:20px;">กำลังรวบรวมข้อมูลประจำเดือน...</td></tr>';
    
    try {
        const res = await fetch(`/api/report/monthly?month=${month}&year=${year}`);
        const data = await res.json();
        let report = data.report || [];
        
        // Filter by scheduled employees only (if any are scheduled in the system)
        const scheduledIds = [...new Set(employees.map(e => String(e.id)))];
        if (scheduledIds.length > 0) {
            report = report.filter(r => scheduledIds.includes(String(r.id)));
        }
        
        if (report.length === 0) {
            body.innerHTML = '';
            empty.style.display = 'block';
            updateMonthlyStats(0, 0, 0);
            return;
        }
        
        empty.style.display = 'none';
        body.innerHTML = report.map(r => `
            <tr style="border-bottom:1px solid var(--border);">
                <td style="padding:12px; font-weight:500;">${r.name}</td>
                <td style="padding:12px; text-align:center;">${r.daysWorked} วัน</td>
                <td style="padding:12px; text-align:center; color:var(--warning); font-weight:600;">${r.lateCount}</td>
                <td style="padding:12px; text-align:center; color:var(--danger);">${Math.max(0, 22 - r.daysWorked)}</td>
                <td style="padding:12px; text-align:center; font-weight:700;">${parseFloat(r.totalHours || 0).toFixed(1)} ชม.</td>
            </tr>
        `).join('');

        const totalDays = report.reduce((sum, r) => sum + r.daysWorked, 0);
        const totalHrs = report.reduce((sum, r) => sum + parseFloat(r.totalHours || 0), 0);
        const totalLate = report.reduce((sum, r) => sum + r.lateCount, 0);
        updateMonthlyStats(totalDays, totalHrs, totalLate);
        
    } catch(err) {
        body.innerHTML = '<tr><td colspan="5" style="text-align:center; color:red; padding:20px;">เกิดข้อผิดพลาดในการโหลดรายงานรายเดือน</td></tr>';
    }
}

function updateMonthlyStats(days, hrs, late) {
    document.getElementById('monthly-stat-days').textContent = days;
    document.getElementById('monthly-stat-hours').textContent = hrs.toFixed(1);
    document.getElementById('monthly-stat-late').textContent = late;
}
async function fetchDailyReportData() {
    const dateInput = document.getElementById('report-date-input');
    if (!dateInput.value) {
        dateInput.value = new Date().toISOString().split('T')[0];
    }
    const targetDate = dateInput.value;
    const body = document.getElementById('daily-report-body');
    const empty = document.getElementById('daily-report-empty');
    
    body.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px;">กำลังโหลดข้อมูล...</td></tr>';
    
    try {
        const res = await fetch(`/api/data?date=${targetDate}`);
        if (!res.ok) throw new Error('API Error');
        const data = await res.json();
        let emps = data.employees || [];
        
        // Filter: Keep only employees that are present in our global 'employees' schedule for the targetDate
        const scheduledIds = employees.filter(e => e.date === targetDate && e.shift && e.shift !== 'EMPTY').map(e => String(e.id));
        
        emps = emps.filter(e => scheduledIds.includes(String(e.id)));
        
        if (emps.length === 0) {
            body.innerHTML = '';
            empty.style.display = 'block';
            return;
        }
        
        empty.style.display = 'none';
        body.innerHTML = emps.map(e => {
            let hoursStr = e.hours || '0';
            // Calculate hours if out time exists and hours is 0
            if (e.in && e.out && (!e.hours || e.hours === '0' || e.hours === 0)) {
                try {
                    const [inH, inM] = e.in.split(':').map(Number);
                    const [outH, outM] = e.out.split(':').map(Number);
                    if (!isNaN(inH) && !isNaN(outH)) {
                        let totalMins = (outH * 60 + outM) - (inH * 60 + inM);
                        if (totalMins < 0) totalMins += 24 * 60; // handle midnight rollover
                        const hrs = Math.floor(totalMins / 60);
                        const mins = totalMins % 60;
                        hoursStr = `${hrs}.${mins.toString().padStart(2, '0')}`;
                    }
                } catch(e) {}
            }
            
            return `
            <tr style="border-bottom:1px solid var(--border);">
                <td style="padding:12px; font-weight:500;">${e.name}</td>
                <td style="padding:12px; font-size:12px; color:var(--text2);">${e.dept}</td>
                <td style="padding:12px; text-align:center;">
                    <span class="tag ${e.status === 'in' ? 'tag-morning' : e.status === 'late' ? 'tag-morning' : e.status === 'out' ? 'tag-night' : 'tag-empty'}">
                        ${e.status === 'in' ? 'เข้างาน' : e.status === 'late' ? 'มาสาย' : e.status === 'out' ? 'ออกงาน' : 'ยังไม่มา'}
                    </span>
                </td>
                <td style="padding:12px; text-align:center; font-family:var(--mono);">${e.in || '-'}</td>
                <td style="padding:12px; text-align:center; font-family:var(--mono);">${e.out || '-'}</td>
                <td style="padding:12px; text-align:center; font-weight:600; color:var(--accent);">${hoursStr} ชม.</td>
            </tr>
        `}).join('');
        
    } catch(err) {
        body.innerHTML = '<tr><td colspan="6" style="text-align:center; color:red; padding:20px;">เกิดข้อผิดพลาดในการโหลดข้อมูล</td></tr>';
    }
}

