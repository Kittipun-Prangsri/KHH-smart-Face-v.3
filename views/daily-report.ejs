<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>รายงานรายวัน - MediFace Attend</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
<link rel="stylesheet" href="/css/style.css" />
<style>.page-empty { padding: 40px 24px; text-align: center; color: var(--muted); }</style>
</head>
<body>
<%- include("components/sidebar") %>
<div class="main">
<%- include("components/topbar") %>
<!-- PAGE -->
<div class="page">

  <!-- STAT ROW -->
  <div class="stat-row" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-bottom: 24px;">
    <div class="stat-box">
      <div class="stat-ico s1"><i class="bi bi-people-fill"></i></div>
      <div>
        <div class="stat-val" id="totalStaff">0</div>
        <div class="stat-lbl">บุคลากรทั้งหมด</div>
      </div>
    </div>
    <div class="stat-box">
      <div class="stat-ico s2" style="background:#ECFDF5; color:#10B981;"><i class="bi bi-door-open-fill"></i></div>
      <div>
        <div class="stat-val" id="totalIn">0</div>
        <div class="stat-lbl">เข้างานแล้ว</div>
      </div>
    </div>
    <div class="stat-box">
      <div class="stat-ico s2"><i class="bi bi-box-arrow-right"></i></div>
      <div>
        <div class="stat-val" id="totalOut">0</div>
        <div class="stat-lbl">ออกงานแล้ว</div>
      </div>
    </div>
    <div class="stat-box">
      <div class="stat-ico s3"><i class="bi bi-clock-fill"></i></div>
      <div>
        <div class="stat-val" id="totalLate">0</div>
        <div class="stat-lbl">มาสาย</div>
      </div>
    </div>
    <div class="stat-box">
      <div class="stat-ico s1" style="background:#FEF3C7; color:#D97706;"><i class="bi bi-calendar-event-fill"></i></div>
      <div>
        <div class="stat-val" id="totalLeave">0</div>
        <div class="stat-lbl">ลา / ไปราชการ</div>
      </div>
    </div>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar" style="margin-bottom: 24px;">
    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;flex:1;">
      <div class="input-group" style="max-width:220px;">
        <span class="input-group-text" style="background:#F8FAFC;border-color:var(--border);border-radius:10px 0 0 100px;padding-left:15px;"><i class="bi bi-calendar3" style="color:var(--muted)"></i></span>
        <input type="date" class="form-control" id="dateInput" style="border-radius:0 100px 100px 0; padding-right:15px;" onchange="fetchReportData()"/>
      </div>
      <select class="form-select" style="max-width:200px; border-radius:100px;" id="deptFilter" onchange="applyFilters()">
        <option value="">ทุกกลุ่มงาน</option>
        <option>กลุ่มงานประกันสุขภาพยุทธศาสตร์</option>
        <option>กลุ่มงานบริหารทั่วไป</option>
        <option>กลุ่มงานบริการด้านปฐมภูมิและองค์รวม</option>
        <option>กลุ่มงานเภสัชกรรมและคุ้มครองผู้บริโภค</option>
        <option>กลุ่มงานสุขภาพดิจิทัล</option>
        <option>กลุ่มงานการพยาบาล</option>
        <option>กลุ่มงานทันตกรรม</option>
        <option>กลุ่มงานเทคนิคการแพทย์</option>
        <option>กลุ่มงานเวชกรรมฟื้นฟู</option>
        <option>กลุ่มงานการแพทย์แผนไทยและการแพทย์ทางเลือก</option>
        <option>กลุ่มงานรังสีวิทยา</option>
        <option>กลุ่มงานจิตเวชและยาเสพติด</option>
        <option>กลุ่มงานการแพทย์</option>
      </select>
      <div class="input-group" style="max-width:250px;">
        <span class="input-group-text" style="background:transparent; border:none; position:absolute; z-index:5;"><i class="bi bi-search" style="color:var(--muted)"></i></span>
        <input type="text" class="form-control" placeholder="ค้นหาชื่อพนักงาน..." style="border-radius:100px; padding-left:35px;" id="searchInput" oninput="applyFilters()"/>
      </div>
    </div>
    <div style="display:flex;gap:10px;">
      <button class="btn-outline-dark" style="border-radius:100px;" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i> Excel</button>
      <button class="btn-teal" style="border-radius:100px;" onclick="window.print()"><i class="bi bi-printer"></i> พิมพ์รายงาน</button>
    </div>
  </div>

  <!-- REPORT TABLE -->
  <div class="table-card" style="border-radius:20px; overflow:hidden;">
    <div class="card-top" style="padding: 20px 24px; background: #fff;">
      <div>
        <h5 style="margin:0; font-weight:700; color:var(--primary);">สรุปรายงานการเข้ากะรายบุคคล</h5>
        <p style="margin:5px 0 0; font-size:12px; color:var(--muted);" id="reportSubtitle">ข้อมูลประจำวัน...</p>
      </div>
    </div>
    <div style="overflow-x:auto;">
      <table class="att-tbl">
        <thead>
          <tr style="background: #F8FAFC;">
            <th style="width: 60px; text-align:center;">ลำดับ</th>
            <th>ชื่อ-นามสกุล</th>
            <th>กลุ่มงาน / ตำแหน่ง</th>
            <th style="text-align:center;">สถานะ</th>
            <th style="text-align:center;">เวลาเข้า</th>
            <th style="text-align:center;">เวลาออก</th>
            <th style="text-align:center;">รวมเวลา</th>
            <th>หมายเหตุ</th>
          </tr>
        </thead>
        <tbody id="reportTableBody">
          <!-- Rows will be injected here -->
        </tbody>
      </table>
    </div>
    <div id="emptyState" style="display:none; padding:60px 20px; text-align:center; color:var(--muted);">
      <i class="bi bi-inbox" style="font-size:48px; opacity:0.3; display:block; margin-bottom:15px;"></i>
      <p>ไม่พบข้อมูลการเข้างานในวันที่เลือก</p>
    </div>
    <div class="pager" style="padding: 15px 24px; background: #F8FAFC; border-top: 1px solid var(--border);">
      <div class="pager-info" id="reportPagerInfo">แสดง 0 รายการ</div>
    </div>
  </div>

</div>

<script>
  let reportData = [];
  let filteredData = [];

  // Helper for Status Tags
  const STATUS_TAGS = {
    'in': '<span class="status-chip chip-in">เข้างาน</span>',
    'out': '<span class="status-chip chip-out">ออกงาน</span>',
    'late': '<span class="status-chip chip-late">มาสาย</span>',
    'leave': '<span class="status-chip" style="background:#FEF3C7; color:#D97706; border-color:#FCD34D;">ลา/ไปราชการ</span>',
    'none': '<span class="status-chip chip-absent">ยังไม่มา</span>',
    'absent': '<span class="status-chip chip-absent">ขาดงาน</span>'
  };

  async function fetchReportData() {
    const dateInput = document.getElementById('dateInput');
    const targetDate = dateInput.value;
    if (!targetDate) return;

    // Update Subtitle
    const d = new Date(targetDate);
    document.getElementById('reportSubtitle').textContent = `ข้อมูลประจำวันที่ ${d.toLocaleDateString('th-TH', { weekday:'long', day:'numeric', month:'long', year:'numeric' })}`;

    try {
      // Use the existing API
      const res = await fetch(`/api/data?date=${targetDate}`);
      if (res.ok) {
        const db = await res.json();
        reportData = db.employees || [];
        applyFilters();
        updateSummaryStats();
      }
    } catch (err) {
      console.error('Fetch error:', err);
    }
  }

  function applyFilters() {
    const dept = document.getElementById('deptFilter').value;
    const search = document.getElementById('searchInput').value.toLowerCase();

    filteredData = reportData.filter(e => {
      const matchDept = !dept || e.dept === dept;
      const matchSearch = !search || e.name.toLowerCase().includes(search) || (e.id && e.id.toLowerCase().includes(search));
      return matchDept && matchSearch;
    });

    renderReportTable();
  }

  function updateSummaryStats() {
    document.getElementById('totalStaff').textContent = reportData.length;
    document.getElementById('totalIn').textContent = reportData.filter(e => e.status === 'in' || e.status === 'late').length;
    document.getElementById('totalOut').textContent = reportData.filter(e => e.status === 'out').length;
    document.getElementById('totalLate').textContent = reportData.filter(e => e.status === 'late').length;
    document.getElementById('totalLeave').textContent = reportData.filter(e => e.status === 'leave').length;
  }

  function renderReportTable() {
    const tbody = document.getElementById('reportTableBody');
    const empty = document.getElementById('emptyState');
    
    if (filteredData.length === 0) {
      tbody.innerHTML = '';
      empty.style.display = 'block';
      document.getElementById('reportPagerInfo').textContent = 'ไม่มีรายการที่จะแสดง';
      return;
    }

    empty.style.display = 'none';
    tbody.innerHTML = filteredData.map((e, idx) => {
      const statusHtml = STATUS_TAGS[e.status] || STATUS_TAGS['none'];
      const timeIn = e.in || '-';
      const timeOut = e.out && e.out !== e.in ? e.out : '-';
      const hours = e.hours || '0';
      const remark = e.leave_status || '';

      return `
        <tr>
          <td style="text-align:center; color:var(--muted); font-size:12px;">${idx + 1}</td>
          <td>
            <div style="font-weight:600; color:var(--primary);">${e.name}</div>
            <div style="font-size:10px; color:var(--muted);">ID: ${e.id || '-'}</div>
          </td>
          <td>
            <div style="font-size:12px;">${e.dept || '-'}</div>
            <div style="font-size:10px; color:var(--muted);">${e.role || '-'}</div>
          </td>
          <td style="text-align:center;">${statusHtml}</td>
          <td style="text-align:center;"><span class="time-tag">${timeIn}</span></td>
          <td style="text-align:center;"><span class="time-tag ${timeOut !== '-' ? 'out' : ''}">${timeOut}</span></td>
          <td style="text-align:center; font-weight:700; color:var(--primary); font-size:13px;">${hours} <small style="font-size:10px; color:var(--muted);">ชม.</small></td>
          <td style="font-size:11px; color:#D97706; font-weight:500;">${remark}</td>
        </tr>
      `;
    }).join('');

    document.getElementById('reportPagerInfo').textContent = `แสดงทั้งหมด ${filteredData.length} รายการ`;
  }

  function exportExcel() {
    alert('ส่งออกไฟล์ Excel สำหรับวันที่ ' + document.getElementById('dateInput').value);
    // Logic for actual export can be added here
  }

  // Initialize
  window.onload = () => {
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('dateInput').value = today;
    fetchReportData();
  };
</script>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>