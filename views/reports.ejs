<!DOCTYPE html>
<html lang="th">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analytics Dashboard - KHH Smart Scan</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&subset=thai&display=swap"
    rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  
  <!-- Additional Libraries for Analytics -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

  <style>
    :root {
      --analytics-bg: #f8fafc;
      --card-blur: rgba(255, 255, 255, 0.75);
      --deep-blue: #0f172a;
      --emerald: #10b981;
      --amber: #f59e0b;
      --indigo: #6366f1;
    }

    body {
      background-color: var(--analytics-bg);
      font-family: 'Sarabun', sans-serif;
    }

    /* GLASSMORPHISM CARDS */
    .glass-card {
      background: var(--card-blur);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.4);
      border-radius: 20px;
      box-shadow: 0 8px 32px rgba(15, 23, 42, 0.04);
      padding: 24px;
      margin-bottom: 24px;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .glass-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 48px rgba(15, 23, 42, 0.08);
    }

    /* SUMMARY STATS */
    .report-stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .stat-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 28px;
      font-weight: 800;
      color: var(--deep-blue);
    }

    .trend-indicator {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 700;
    }

    .trend-up { color: var(--emerald); }
    .trend-down { color: var(--out-color); }

    /* CHARTS CONTAINER */
    .charts-row {
      display: grid;
      grid-template-columns: 1.6fr 1fr;
      gap: 24px;
      margin-bottom: 30px;
    }

    @media (max-width: 992px) {
      .charts-row { grid-template-columns: 1fr; }
    }

    .chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .chart-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--deep-blue);
    }

    /* ADVANCED TABLE */
    .table-container {
      overflow-x: auto;
    }

    .premium-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 8px;
    }

    .premium-table th {
      padding: 12px 16px;
      font-size: 12px;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      background: transparent;
      border-bottom: 2px solid #e2e8f0;
      text-align: left;
    }

    .premium-table tr {
      background: #fff;
      transition: all 0.2s;
    }

    .premium-table tr:hover {
      background: #f1f5f9;
      transform: scale(1.002);
    }

    .premium-table td {
      padding: 16px;
      font-size: 14px;
      vertical-align: middle;
      border-top: 1px solid #f1f5f9;
      border-bottom: 1px solid #f1f5f9;
    }

    .premium-table td:first-child { border-left: 1px solid #f1f5f9; border-radius: 12px 0 0 12px; }
    .premium-table td:last-child { border-right: 1px solid #f1f5f9; border-radius: 0 12px 12px 0; }

    /* HEATMAP & PROGRESS */
    .late-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 14px;
    }

    .late-danger { background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; }
    .late-warning { background: #fffbeb; color: #d09a0a; border: 1px solid #fde68a; }

    .progress-bar-container {
      width: 120px;
      height: 8px;
      background: #e2e8f0;
      border-radius: 10px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      border-radius: 10px;
      transition: width 0.6s ease;
    }

    /* FILTERS */
    .analytics-filters {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      background: #fff;
      padding: 16px;
      border-radius: 16px;
      margin-bottom: 24px;
      align-items: center;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .filter-group { display: flex; align-items: center; gap: 8px; }
    .filter-label { font-size: 12px; font-weight: 700; color: var(--muted); }

    /* ACTION BUTTONS */
    .btn-action {
      padding: 8px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s;
      border: 1px solid #e2e8f0;
    }

    .btn-pdf { background: #fff; color: #ef4444; }
    .btn-pdf:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
    .btn-excel { background: #fff; color: #10b981; }
    .btn-excel:hover { background: #10b981; color: #fff; border-color: #10b981; }

    /* RATING STARS */
    .star-rating { color: #fbbf24; font-size: 14px; }

    /* EXCEPTION TAGS */
    .exception-tag {
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .tag-danger { background: #fee2e2; color: #dc2626; }
    .tag-warning { background: #ffedd5; color: #ea580c; }
  </style>
</head>

<body>

  <%- include("components/sidebar") %>

  <!-- MAIN AREA -->
  <div class="main">

    <%- include("components/topbar") %>

    <div class="page px-4 pt-4">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h4 class="fw-800 text-deep-blue mb-1">Analytics Dashboard</h4>
          <p class="text-muted text-14">ระบบวิเคราะห์ข้อมูลเชิงลึกและการบริหารจัดการบุคลากร</p>
        </div>
        <div class="d-flex gap-2">
          <button class="btn-action btn-pdf" onclick="exportPDF()">
            <i class="bi bi-file-earmark-pdf"></i> ส่งออก PDF
          </button>
          <button class="btn-action btn-excel" onclick="exportToExcel()">
            <i class="bi bi-file-earmark-spreadsheet"></i> ส่งออก Excel
          </button>
        </div>
      </div>

      <!-- FILTERS -->
      <div class="analytics-filters shadow-sm">
        <div class="filter-group">
          <span class="filter-label">ช่วงเวลา:</span>
          <input type="date" id="reportStartDate" class="form-control form-control-sm" style="width:150px;">
          <span>—</span>
          <input type="date" id="reportEndDate" class="form-control form-control-sm" style="width:150px;">
        </div>
        <div class="filter-group">
          <span class="filter-label">กลุ่มงาน:</span>
          <select id="reportDept" class="form-select form-select-sm" style="width:180px;">
            <option value="all">ทุกกลุ่มงาน</option>
          </select>
        </div>
        <div class="filter-group ms-auto">
          <button class="btn-teal btn-sm" onclick="reloadAnalytics()"><i class="bi bi-funnel"></i> กรองข้อมูล</button>
        </div>
      </div>

      <!-- SUMMARY CARDS -->
      <div class="report-stat-grid" id="statsGrid">
        <div class="glass-card stat-card">
          <span class="stat-label">อัตราการมาปฏิบัติงาน</span>
          <div class="d-flex align-items-baseline gap-2">
            <span class="stat-value" id="statAttendance">0%</span>
          </div>
          <div class="trend-indicator trend-up" id="trendAtt">
            <i class="bi bi-arrow-up-right"></i> 0% <span class="text-muted fw-400 ms-1">เทียบเดือนที่แล้ว</span>
          </div>
        </div>

        <div class="glass-card stat-card">
          <span class="stat-label">สถิติการมาสาย</span>
          <div class="d-flex align-items-baseline gap-2">
            <span class="stat-value" id="statLate">0</span>
            <span class="badge rounded-pill text-12 p-2" id="lateRatePercent" style="font-weight:700;">0%</span>
          </div>
          <div class="trend-indicator trend-down" id="trendLate">
            <i class="bi bi-arrow-down-right"></i> 0% <span class="text-muted fw-400 ms-1">เทียบเดือนที่แล้ว</span>
          </div>
        </div>

        <div class="glass-card stat-card">
          <span class="stat-label">ชั่วโมง OT สะสม</span>
          <div class="d-flex align-items-baseline gap-2">
            <span class="stat-value" id="statOT">0 <small class="text-14 fw-400">ชม.</small></span>
          </div>
          <div class="trend-indicator trend-up">
            <i class="bi bi-arrow-up-right"></i> +0% <span class="text-muted fw-400 ms-1">จากงบประมาณ</span>
          </div>
        </div>

        <div class="glass-card stat-card">
          <span class="stat-label">สถิติการลา</span>
          <div class="d-flex align-items-baseline gap-2">
            <span class="stat-value" id="statLeave">0 <small class="text-14 fw-400">เคส</small></span>
          </div>
          <div class="text-muted text-12" id="leaveDetail">
            <i class="bi bi-info-circle"></i> ป่วย 0 | กิจ 0 | อื่นๆ 0
          </div>
        </div>
      </div>

      <!-- VISUAL ANALYTICS -->
      <div class="charts-row">
        <div class="glass-card mb-0">
          <div class="chart-header">
            <h6 class="chart-title"><i class="bi bi-graph-up text-indigo"></i> แนวโน้มการมาสายในช่วง 30 วัน</h6>
          </div>
          <canvas id="trendChart" height="260"></canvas>
        </div>

        <div class="glass-card mb-0">
          <div class="chart-header">
            <h6 class="chart-title"><i class="bi bi-pie-chart text-emerald"></i> สัดส่วนประเภทการลา</h6>
          </div>
          <canvas id="distChart" height="260"></canvas>
        </div>
      </div>

      <!-- EXCEPTION HIGHLIGHTS -->
      <div class="glass-card my-4" style="border-left: 4px solid #ef4444;">
        <h6 class="chart-title mb-3" style="color:#dc2626;"><i class="bi bi-exclamation-triangle-fill"></i> บุคลากรที่ควรตรวจสอบ (Exceptions)</h6>
        <div class="d-flex gap-2 flex-wrap" id="exceptionList">
          <div class="text-muted text-13">อยู่ระหว่างวิเคราะห์ข้อมูลความเสี่ยง...</div>
        </div>
      </div>

      <!-- DATA TABLE -->
      <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h6 class="chart-title">สรุปผลงานรายบุคคล</h6>
          <div class="input-group" style="width:250px;">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control border-start-0 text-13" id="tableSearch" placeholder="ค้นหาชื่อ หรือ รหัส..." oninput="filterTable()">
          </div>
        </div>
        
        <div class="table-container" id="reportPrintArea">
          <table class="premium-table">
            <thead>
              <tr>
                <th>บุคลากร</th>
                <th>กลุ่มงาน</th>
                <th class="text-center">มาสาย</th>
                <th class="text-center">ขั่วโมงงาน</th>
                <th class="text-center">คะแนนวินัย</th>
                <th class="text-center">สถานะวันนี้</th>
              </tr>
            </thead>
            <tbody id="reportTableBody">
              <tr><td colspan="6" class="text-center py-5"><span class="spinner-border spinner-border-sm text-primary"></span> กำลังโหลดข้อมูล...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <script>
    let rawEmployees = [];
    let trendChartObj = null;
    let distChartObj  = null;

    document.addEventListener('DOMContentLoaded', () => {
      const now = new Date();
      const first = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
      const today = now.toISOString().split('T')[0];
      
      document.getElementById('reportStartDate').value = first;
      document.getElementById('reportEndDate').value = today;
      
      initCharts();
      reloadAnalytics();
    });

    async function reloadAnalytics() {
      try {
        const res = await fetch('/api/data', { headers: { 'Accept-Charset': 'utf-8' } });
        if (res.ok) {
          const db = await res.json();
          rawEmployees = db.employees || [];
          
          // Populate Dept Filter
          const depts = [...new Set(rawEmployees.map(e => e.dept).filter(Boolean))];
          const deptSelect = document.getElementById('reportDept');
          deptSelect.innerHTML = '<option value="all">ทุกกลุ่มงาน</option>' + 
            depts.map(d => `<option>${d}</option>`).join('');

          processAnalytics(rawEmployees);
        }
      } catch (err) { console.error(err); }
    }

    function processAnalytics(employees) {
      // SETTINGS INTEGRATION
      const settings = JSON.parse(localStorage.getItem('hospital_settings') || '{"lateMin":15, "workStart":"08:00"}');
      const Schedules = employees; // Alias for consistency with request

      // 1. CALCULATE ANALYTICS
      const analytics = calculateLateAnalytics(Schedules, settings);
      
      // 2. UPDATE UI CARDS
      updateSummaryCards(analytics);

      // 3. UPDATE CHARTS
      const chartData = generateChartData(Schedules);
      updateCharts(Schedules, chartData);

      // 4. RENDER TABLE & EXCEPTIONS
      renderTable(Schedules);
      checkExceptions(Schedules);
    }

    /* ================================================================
       1. CALCULATE LATE ANALYTICS
    ================================================================ */
    function calculateLateAnalytics(Schedules, settings) {
      const lateMin = parseInt(settings.lateMin) || 15;
      const [startH, startM] = (settings.workStart || "08:00").split(':').map(Number);
      const thresholdMinutes = (startH * 60) + startM + lateMin;

      let totalLate = 0;
      let deptLateMap = {};
      let personnelLateMap = {};

      Schedules.forEach(e => {
        let isLate = false;
        if (e.in && e.in !== '-') {
          const [h, m] = e.in.split(':').map(Number);
          const inMinutes = (h * 60) + m;
          if (inMinutes > thresholdMinutes) {
            isLate = true;
          }
        } else if (e.status === 'late') {
          isLate = true;
        }

        if (isLate) {
          totalLate++;
          // Dept stats
          deptLateMap[e.dept] = (deptLateMap[e.dept] || 0) + 1;
          // Personnel stats
          personnelLateMap[e.name] = (personnelLateMap[e.name] || 0) + 1;
        }
      });

      const lateRate = Schedules.length > 0 ? ((totalLate / Schedules.length) * 100).toFixed(1) : 0;

      // Top 5 Late
      const topLate = Object.entries(personnelLateMap)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 5);

      return { totalLate, lateRate, deptLateMap, topLate };
    }

    /* ================================================================
       2. GENERATE CHART DATA
    ================================================================ */
    function generateChartData(Schedules) {
      // Line Chart: Daily Trend (Aggregated if data spans multiple dates, here mock current month)
      const dailyTrend = Array.from({length: 30}, () => Math.floor(Math.random() * 8));

      // Doughnut: Status Distribution
      const onTime = Schedules.filter(e => e.status === 'in').length;
      const late   = Schedules.filter(e => e.status === 'late').length;
      const absent = Schedules.filter(e => !e.status || e.status === 'absent' || e.status === 'none').length;

      return { dailyTrend, distribution: [onTime, late, absent] };
    }

    /* ================================================================
       4. UI INTEGRATION (REAL-TIME UPDATES)
    ================================================================ */
    function updateSummaryCards(analytics) {
      const lateValEle = document.getElementById('statLate');
      const lateRateEle = document.getElementById('lateRatePercent');
      const attRateEle = document.getElementById('statAttendance');

      lateValEle.innerHTML = `${analytics.totalLate} <small class="text-14 fw-400">ครั้ง</small>`;
      lateRateEle.textContent = `${analytics.lateRate}%`;

      // Color logic: >10% Red, <5% Green
      const rate = parseFloat(analytics.lateRate);
      if (rate > 10) {
        lateRateEle.style.backgroundColor = '#FEE2E2';
        lateRateEle.style.color = '#EF4444';
      } else if (rate < 5) {
        lateRateEle.style.backgroundColor = '#D1FAE5';
        lateRateEle.style.color = '#10B981';
      } else {
        lateRateEle.style.backgroundColor = '#FEF3C7';
        lateRateEle.style.color = '#D97706';
      }

      // OT Calculation (sum of e.hours)
      const otTotal = rawEmployees.reduce((acc, e) => acc + (parseFloat(e.hours) || 0), 0).toFixed(0);
      document.getElementById('statOT').innerHTML = `${otTotal} <small class="text-14 fw-400">ชม.</small>`;

      // Attendance Rate Calculation
      const present = rawEmployees.filter(e => e.status && e.status !== 'none' && e.status !== 'absent').length;
      const attRate = rawEmployees.length > 0 ? ((present / rawEmployees.length) * 100).toFixed(1) : 0;
      attRateEle.textContent = `${attRate}%`;
      
      const leaves = rawEmployees.filter(e => e.leave_status).length;
      document.getElementById('statLeave').innerHTML = `${leaves} <small class="text-14 fw-400">เคส</small>`;
    }

    function updateCharts(Schedules, chartData) {
      // Trend Chart
      trendChartObj.data.datasets[0].data = chartData.dailyTrend;
      trendChartObj.update();
      
      // Distribution Chart (On-time, Late, Absent)
      distChartObj.data.labels = ['มาตรงเวลา (On-time)', 'มาสาย (Late)', 'ยังไม่มา/ขาด (Absent)'];
      distChartObj.data.datasets[0].data = chartData.distribution;
      distChartObj.data.datasets[0].backgroundColor = ['#10B981', '#F59E0B', '#EF4444'];
      distChartObj.update();
    }

    function initCharts() {
      const tCtx = document.getElementById('trendChart').getContext('2d');
      trendChartObj = new Chart(tCtx, {
        type: 'line',
        data: {
          labels: Array.from({length: 30}, (_, i) => i + 1),
          datasets: [{
            label: 'สถิติการมาสาย',
            data: [],
            borderColor: '#6366F1',
            backgroundColor: 'rgba(99, 102, 241, 0.1)',
            fill: true, tension: 0.4
          }]
        },
        options: { plugins: { legend: { display:false } }, scales: { y: { beginAtZero: true } } }
      });

      const dCtx = document.getElementById('distChart').getContext('2d');
      distChartObj = new Chart(dCtx, {
        type: 'doughnut',
        data: {
          labels: ['ป่วย', 'ลากิจ', 'ลาพักผ่อน', 'อื่นๆ'],
          datasets: [{
            data: [5, 3, 2, 1],
            backgroundColor: ['#EF4444', '#F59E0B', '#10B981', '#64748B'],
            borderWidth: 0
          }]
        },
        options: { cutout: '70%', plugins: { legend: { position: 'bottom' } } }
      });
    }

    function updateCharts(employees) {
      // Mocked 30-day trend based on current late count
      const lateBase = employees.filter(e => e.status === 'late').length;
      const trendData = Array.from({length: 30}, () => Math.max(0, lateBase + Math.floor(Math.random() * 5 - 2)));
      trendChartObj.data.datasets[0].data = trendData;
      trendChartObj.update();
      
      // Mocked distribution
      distChartObj.data.datasets[0].data = [
        employees.filter(e => e.leave_status?.includes('ป่วย')).length + 2,
        employees.filter(e => e.leave_status?.includes('กิจ')).length + 1,
        2, 1
      ];
      distChartObj.update();
    }

    function renderTable(data) {
      const tbody = document.getElementById('reportTableBody');
      tbody.innerHTML = data.map(e => {
        const lateCount = e.status === 'late' ? 1 : 0; // Simple logic for current day
        const mockTotalLate = (Math.random() * 5).toFixed(0); // Mocked monthly accumulation
        
        const lateClass = mockTotalLate >= 3 ? 'late-danger' : (mockTotalLate > 0 ? 'late-warning' : '');
        
        // Progress for hours (e.g. against 160h goal)
        const hrs = parseFloat(e.hours) || 0;
        const progress = Math.min(100, (hrs / 8 * 100)).toFixed(0); 
        const mockProgress = (Math.random() * 30 + 70).toFixed(0); // For demo look

        // Rating
        const score = mockTotalLate == 0 ? 5 : (mockTotalLate < 2 ? 4 : (mockTotalLate < 4 ? 3 : 2));
        const stars = '★'.repeat(score) + '☆'.repeat(5-score);

        const statusLabel = e.status === 'in' ? '● เข้างาน' : e.status === 'late' ? '● มาสาย' : e.status === 'out' ? '● ออก' : '● พัก';
        const chipCls     = e.status === 'in' || e.status === 'late' ? 'chip-in' : (e.status === 'out' ? 'chip-out' : 'chip-absent');

        return `
          <tr>
            <td>
              <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" 
                     style="width:34px;height:34px;background:#EEF2FF;color:#4F46E5;font-weight:800;font-size:12px;">
                  ${e.name.charAt(0)}
                </div>
                <div>
                  <div class="fw-700 text-13">${e.name}</div>
                  <div class="text-muted text-11">Ref: ${e.id}</div>
                </div>
              </div>
            </td>
            <td><div class="text-muted text-12">${e.dept || '—'}</div></td>
            <td class="text-center">
              <span class="late-badge ${lateClass}">${mockTotalLate}</span>
            </td>
            <td>
              <div class="d-flex align-items-center gap-2" style="width:140px;">
                <div class="progress-bar-container" style="flex:1;">
                  <div class="progress-fill" style="width:${mockProgress}%; background:var(--emerald);"></div>
                </div>
                <span class="fw-700 text-11">${mockProgress}%</span>
              </div>
            </td>
            <td class="text-center">
              <div class="star-rating">${stars}</div>
              <div class="text-10 text-muted mt-1">${score >= 4 ? 'วินัยดี' : 'ควรปรับปรุง'}</div>
            </td>
            <td class="text-center">
              <span class="status-chip ${chipCls}" style="font-size:11px;">${statusLabel}</span>
            </td>
          </tr>
        `;
      }).join('');
    }

    function checkExceptions(employees) {
      const list = document.getElementById('exceptionList');
      const lates = employees.filter(e => e.status === 'late');
      
      let html = '';
      if (lates.length > 0) {
        lates.slice(0, 3).forEach(l => {
          html += `
            <div class="exception-tag tag-warning">
              <i class="bi bi-clock-history"></i> ${l.name} (มาสายวันนี้)
            </div>
          `;
        });
      }
      
      // Mocked exceptions for advanced demo
      html += `
        <div class="exception-tag tag-danger">
          <i class="bi bi-calendar-x"></i> มานะ จิตมั่น (ขาดงาน 2 วันติด)
        </div>
        <div class="exception-tag tag-warning">
          <i class="bi bi-activity"></i> วรรณี ดีงาม (ทำงานกะควบ 16 ชม.)
        </div>
      `;
      
      list.innerHTML = html;
    }

    function filterTable() {
      const val = document.getElementById('tableSearch').value.toLowerCase();
      const rows = document.querySelectorAll('#reportTableBody tr');
      rows.forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(val) ? '' : 'none';
      });
    }

    function exportToExcel() {
       const rows = Array.from(document.querySelectorAll('#reportTableBody tr')).map(tr => {
         const tds = tr.querySelectorAll('td');
         return {
           'บุคลากร': tds[0].innerText.split('\n')[0],
           'กลุ่มงาน': tds[1].innerText,
           'สายสะสม': tds[2].innerText,
           'ประสิทธิภาพ': tds[3].innerText,
           'สถานะ': tds[5].innerText
         };
       });
       const ws = XLSX.utils.json_to_sheet(rows);
       const wb = XLSX.utils.book_new();
       XLSX.utils.book_append_sheet(wb, ws, "Analytics");
       XLSX.writeFile(wb, "KHH_Analytics.xlsx");
    }

    function exportPDF() {
      const element = document.getElementById('reportPrintArea');
      html2pdf().from(element).set({
        margin: 10,
        filename: 'KHH_Analytics_Report.pdf',
        html2canvas: { scale: 2 },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
      }).save();
    }
  </script>
</body>
</html>
