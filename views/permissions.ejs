<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ตั้งค่าระดับสิทธิ์ - KHH Smart Scan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&subset=thai&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .perm-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            padding: 24px;
            margin-bottom: 24px;
        }
        .perm-table th { background: #f8fafc; text-transform: uppercase; font-size: 11px; letter-spacing: 1px; color: #64748b; }
        .perm-table td { vertical-align: middle; padding: 16px; font-size: 14px; }
        .role-badge { 
          padding: 6px 12px; border-radius: 20px; font-weight: 700; font-size: 12px;
          display: inline-flex; align-items: center; gap: 6px;
        }
        .rb-admin { background: #fee2e2; color: #dc2626; }
        .rb-staff { background: #e0f2fe; color: #0284c7; }
        
        .form-check-input:checked { background-color: var(--primary); border-color: var(--primary); }
    </style>
</head>
<body>
    <%- include("components/sidebar") %>
    <div class="main">
        <%- include("components/topbar") %>
        <div class="page p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-800 text-deep-blue mb-1">ตั้งค่าระดับสิทธิ์ (RBAC)</h4>
                    <p class="text-muted text-14">กำหนดขอบเขตการเข้าถึงข้อมูลระหว่าง Admin และ Staff</p>
                </div>
                <div>
                    <button class="btn btn-outline-secondary me-2" onclick="setDefault()">
                      <i class="bi bi-arrow-counterclockwise me-2"></i> Set Default
                    </button>
                    <button class="btn btn-primary" onclick="savePermissions()">
                      <i class="bi bi-floppy-fill me-2"></i> บันทึกการตั้งค่า
                    </button>
                </div>
            </div>

            <div class="row g-4 mb-4">
              <div class="col-md-6">
                <div class="perm-card text-center">
                  <div class="role-badge rb-admin mb-2">ADMIN (ผู้ดูแลระบบ)</div>
                  <p class="small text-muted mb-0">มีสิทธิ์สูงสุดในทุกระบบ จัดการบุคลากรได้ทั้งหมด</p>
                </div>
              </div>
              <div class="col-md-6">
                <div class="perm-card text-center">
                  <div class="role-badge rb-staff mb-2">STAFF (เจ้าหน้าที่)</div>
                  <p class="small text-muted mb-0">ดูข้อมูลส่วนตัวและหน้าหลักแบบจำกัด (ตาม PDPA)</p>
                </div>
              </div>
            </div>

            <div class="perm-card">
                <h6 class="fw-700 mb-3"><i class="bi bi-table text-primary me-2"></i> Permission Matrix</h6>
                <div class="table-responsive">
                    <table class="table perm-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 50%;">ความสามารถ (Capability)</th>
                                <th class="text-center">Admin</th>
                                <th class="text-center">Staff</th>
                            </tr>
                        </thead>
                        <tbody id="permissionBody">
                            <!-- JS populated -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
      const capabilities = [
        { id: 'view_dashboard', name: 'ดูแดชบอร์ดภาพรวม', desc: 'หน้าแรก สถานะองค์ความรวม' },
        { id: 'view_phone', name: 'ดูเบอร์โทรศัพท์ (เต็ม)', desc: 'เข้าถึงข้อมูลติดต่อเบอร์โทรแบบไม่มีการซ่อน' },
        { id: 'view_email', name: 'ดูอีเมลบุคลากร', desc: 'ที่อยู่อีเมลจริงสำหรับติดต่องาน' },
        { id: 'edit_staff', name: 'แก้ไขข้อมูล', desc: 'สิทธิ์ในการแก้ไขข้อมูลในระบบ' },
        { id: 'delete_staff', name: 'ลบข้อมูล', desc: 'สิทธิ์ในการลบข้อมูลออกจากระบบ' },
        { id: 'manage_permissions', name: 'ตั้งค่าสิทธิ์ (Permissions)', desc: 'จัดการสิทธิ์เข้าถึงระบบ' }
      ];

      const defaultState = {
        'admin': ['view_dashboard', 'view_phone', 'view_email', 'edit_staff', 'delete_staff', 'manage_permissions'],
        'staff': ['view_dashboard']
      };

      let currentPerms = JSON.parse(localStorage.getItem('APP_PERMISSIONS')) || defaultState;

      // Compatibility fix from old version
      if (!currentPerms.admin) currentPerms.admin = defaultState.admin;
      if (!currentPerms.staff) currentPerms.staff = defaultState.staff;

      function renderMatrix() {
        const body = document.getElementById('permissionBody');
        body.innerHTML = capabilities.map(cap => `
          <tr>
            <td>
              <div class="fw-700">${cap.name}</div>
              <div class="text-11 text-muted">${cap.desc}</div>
            </td>
            <td class="text-center">
              <input class="form-check-input" type="checkbox" data-role="admin" data-cap="${cap.id}" ${currentPerms.admin.includes(cap.id) ? 'checked' : ''} onchange="togglePerm(this)">
            </td>
            <td class="text-center">
              <input class="form-check-input" type="checkbox" data-role="staff" data-cap="${cap.id}" ${currentPerms.staff.includes(cap.id) ? 'checked' : ''} disabled>
            </td>
          </tr>
        `).join('');
      }

      function togglePerm(el) {
        const role = el.dataset.role;
        const cap = el.dataset.cap;
        if (el.checked) {
          if (!currentPerms[role].includes(cap)) currentPerms[role].push(cap);
        } else {
          currentPerms[role] = currentPerms[role].filter(i => i !== cap);
        }
      }

      function setDefault() {
        if (confirm('คุณต้องการรีเซ็ตสิทธิ์ของ Staff ให้เข้าถึงข้อมูลได้น้อยที่สุด (PDPA) ใช่หรือไม่?')) {
          currentPerms = defaultState;
          renderMatrix();
        }
      }

      function savePermissions() {
        // Enforce Logic: Staff cannot have anything other than view_dashboard
        currentPerms.staff = ['view_dashboard'];
        localStorage.setItem('APP_PERMISSIONS', JSON.stringify(currentPerms));
        alert('บันทึกการตั้งค่าสิทธิ์เรียบร้อยแล้ว');
        window.location.reload();
      }

      document.addEventListener('DOMContentLoaded', renderMatrix);
    </script>
</body>
</html>
