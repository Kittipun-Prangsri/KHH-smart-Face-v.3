<!-- SIDEBAR -->
<nav class="sidebar" id="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-icon" style="background:transparent;"><img src="/images/LOGO%20KHH.jpg" alt="KHH Hospital Logo"
        style="width:100%; height:100%; border-radius:10px; object-fit:cover;" /></div>
    <h5>โรงพยาบาลคลองหาด</h5>
    <small>ระบบสแกนหน้าบุคลากรโรงพยาบาล</small>
  </div>
  <div class="sb-nav">
    <div class="sb-sec">เมนูหลัก</div>
    <a href="/" class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/' ? 'active' : '' %>"><i
        class="bi bi-speedometer2"></i> <span>หน้าหลัก</span></a>

    <a href="/schedule"
       class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/schedule' ? 'active' : '' %>"><i
        class="bi bi-clock-history"></i> <span>ตารางเวรตัวเอง</span></a>

    <!-- Admin Only Menus (Now accessible to all) -->
    <a href="/attendance"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/attendance' ? 'active' : '' %>"><i
        class="bi bi-person-check"></i> <span>บันทึกเข้า-ออกงาน</span></a>
    <a href="/personnel"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/personnel' ? 'active' : '' %>"><i
        class="bi bi-people"></i> <span>ข้อมูลบุคลากร</span></a>
    <a href="/scheduling"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/scheduling' ? 'active' : '' %>"><i
        class="bi bi-calendar2-week-fill"></i> <span>จัดตารางเวรพยาบาล</span></a>
    <a href="/reports"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/reports' ? 'active' : '' %>"><i
        class="bi bi-graph-up-arrow"></i> <span>แดชบอร์ดวิเคราะห์</span></a>
    <a href="/report/daily"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/report/daily' ? 'active' : '' %>"><i
        class="bi bi-bar-chart-line"></i> <span>รายงานสรุปรายวัน</span></a>
    <a href="/report/monthly"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/report/monthly' ? 'active' : '' %>"><i
        class="bi bi-calendar3"></i> <span>รายงานสรุปรายเดือน</span></a>

    <div id="admin-tools">
      <div class="sb-sec">ฝ่ายบริหารระบบ</div>
      <a href="/admin/users"
        class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/admin/users' ? 'active' : '' %>"><i
          class="bi bi-person-gear"></i> <span>จัดการผู้เข้าใช้</span></a>
      <a href="/admin/permissions"
        class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/admin/permissions' ? 'active' : '' %>"><i
          class="bi bi-shield-lock-fill"></i> <span>ตั้งค่าระดับสิทธิ์</span></a>
    </div>

    <script>
      function syncAdminMenu() {
        const adminTools = document.getElementById('admin-tools');
        if (adminTools) {
          // Force Show: Admin tools will now be visible to all for troubleshooting
          adminTools.style.display = 'block';
        }
      }
      // Run on load and also listen for role changes (if any)
      window.addEventListener('DOMContentLoaded', syncAdminMenu);
      // Listen for the custom event from topbar.ejs when role changes
      window.addEventListener('roleChanged', syncAdminMenu);
    </script>
    <a href="/report/hours"
      class="sb-link <%= typeof activeRoute !== 'undefined' && activeRoute === '/report/hours' ? 'active' : '' %>"><i
        class="bi bi-file-earmark-medical"></i> <span>สรุปชั่วโมงทำงาน</span></a>
  </div>
  <div class="sb-foot">
    <div class="sb-user">
      <div class="sb-av">
        <%= locals.user && user.fullname ? user.fullname.charAt(0).toUpperCase() : 'U' %>
      </div>
      <div>
        <div class="sb-uname">
          <%= locals.user && user.fullname ? user.fullname : 'Unregistered User' %>
        </div>
        <div class="sb-urole">
          <% if (locals.user && user.role === 'admin') { %>
            <span class="badge bg-danger" style="font-size: 10px; font-weight: 700;">Administrator</span>
          <% } else { %>
            <span class="badge bg-success" style="font-size: 10px; font-weight: 700;">Staff Member</span>
          <% } %>
        </div>
      </div>
      <a href="/logout" class="ms-auto" title="ออกจากระบบ" style="color:rgba(255,255,255,.5);"><i class="bi bi-box-arrow-right"></i></a>
    </div>
  </div>
</nav>

<!-- MOBILE OVERLAY -->
<div class="sb-overlay" id="sidebar-overlay" onclick="toggleGlobalSidebar()"></div>