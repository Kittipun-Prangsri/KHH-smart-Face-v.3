<!-- TOPBAR -->
<div class="topbar">
  <div class="d-flex align-items:center gap-3">
    <button class="icon-btn me-2" onclick="toggleGlobalSidebar()">
      <i class="bi bi-list"></i>
    </button>

    <script>
      function toggleGlobalSidebar() {
        const sidebar = document.getElementById('sidebar');
        const main = document.querySelector('.main');
        const overlay = document.getElementById('sidebar-overlay');
        
        if (window.innerWidth < 992) {
          sidebar.classList.toggle('mobile-active');
          if (overlay) overlay.classList.toggle('active');
        } else {
          if (sidebar) sidebar.classList.toggle('collapsed');
          if (main) main.classList.toggle('expanded');
        }
      }
    </script>
    <div class="topbar-left">
      <h6>Dashboard - KHH (<%= locals.user ? user.role.toUpperCase() : 'USER' %>)</h6>
      <small id="currentDate">กำลังโหลด...</small>
    </div>
  </div>
  <div class="d-flex align-items:center gap-2" style="display:flex;align-items:center;gap:8px;">
    <div class="live-pill"><span class="live-dot"></span> ระบบออนไลน์</div>
    <div class="icon-btn" title="แจ้งเตือน"><i class="bi bi-bell"></i></div>
    <div class="icon-btn" title="รีเฟรช" onclick="refreshData(this)"><i class="bi bi-arrow-clockwise"></i></div>
    <div class="icon-btn" title="ตั้งค่า" onclick="openSettings()"><i class="bi bi-gear"></i></div>
  </div>
</div>

<script>
  // Actual Logged-in User Role from Session
  const CURRENT_ROLE = "<%= (locals.user && user.role) ? user.role : 'staff' %>";
  const RBAC_ENABLED = false; // ปิดระบบสิทธิ์ชั่วคราว
  console.log('Current User Role:', CURRENT_ROLE, '| RBAC_ENABLED:', RBAC_ENABLED);

  function checkPermission(capability) {
    if (!RBAC_ENABLED) return true;
    if (capability === 'view_dashboard') return true;
    return CURRENT_ROLE === 'admin';
  }

  function maskSensitiveData(str, capability) {
    if (!RBAC_ENABLED) return str;
    if (!str || str === '-') return '-';
    // Admin sees everything
    if (checkPermission(capability)) return str;
    
    // Masking phone example: 08x-xxx-xxxx
    if (capability === 'view_phone') {
        return '08x-xxx-xxxx';
    }
    // Masking email: m****@****.com
    if (capability === 'view_email') {
        return '********'; // completely hide email
    }
    return '********';
  }
</script>