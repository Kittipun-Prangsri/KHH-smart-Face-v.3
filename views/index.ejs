<style>
/* ── SDM Card & Layout ── */
.sdm-card {
  background:#fff; border-radius:20px;
  width:680px; max-width:98vw; max-height:93vh;
  overflow:hidden; display:flex; flex-direction:column;
  box-shadow:0 32px 88px rgba(0,0,0,.32);
  animation:sdmIn .26s cubic-bezier(.22,1,.36,1);
}
@keyframes sdmIn {
  from { opacity:0; transform:translateY(22px) scale(.97); }
  to   { opacity:1; transform:none; }
}

/* ── Header ── */
.sdm-header {
  background:linear-gradient(135deg,#6366f1,#4f46e5);
  padding:22px 24px 18px;
  display:flex; align-items:center; justify-content:space-between;
  flex-shrink:0;
}
.sdm-av {
  width:58px; height:58px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:24px; font-weight:800; color:#fff;
  border:3px solid rgba(255,255,255,.45); flex-shrink:0;
}
.sdm-h-name { font-size:20px; font-weight:800; color:#fff; line-height:1.2; }
.sdm-h-sub  { font-size:12px; color:rgba(255,255,255,.72); margin-top:4px; }

/* ── Header buttons ── */
.sdm-hbtn {
  border:none; background:rgba(255,255,255,.18);
  border-radius:9px; padding:6px 11px;
  color:#fff; font-size:13px; font-weight:600;
  cursor:pointer; display:inline-flex; align-items:center; gap:5px;
  transition:background .15s; font-family:inherit;
}
.sdm-hbtn:hover { background:rgba(255,255,255,.28); }
.sdm-hbtn-save { background:rgba(16,185,129,.7); }
.sdm-hbtn-save:hover { background:rgba(16,185,129,.9); }

/* ── Status strip ── */
.sdm-status-strip {
  padding:11px 24px; background:#f1f5f9;
  border-bottom:1px solid #E2E8F0;
  display:flex; align-items:center; gap:9px; flex-wrap:wrap;
  flex-shrink:0;
}

/* ── Tabs bar ── */
.sdm-tabs-bar {
  display:flex; gap:2px; padding:10px 16px 0;
  background:#fff; border-bottom:2px solid #E2E8F0;
  flex-shrink:0;
}
.sdm-tab {
  padding:8px 18px; border:none; background:none;
  border-radius:8px 8px 0 0; font-size:13px; font-weight:600;
  color:#94A3B8; cursor:pointer; font-family:inherit;
  display:inline-flex; align-items:center; gap:7px;
  border-bottom:3px solid transparent; margin-bottom:-2px;
  transition:all .18s;
}
.sdm-tab.active { color:#6366f1; border-bottom-color:#6366f1; background:#EEF2FF; }
.sdm-tab:hover:not(.active) { background:#F8FAFC; }

/* ── Tab panel ── */
.sdm-panel { padding:20px 22px 24px; }

/* ── Field cards ── */
.sdm-field-card {
  background:#fff; border:1px solid #E2E8F0;
  border-radius:13px; padding:13px 14px;
  display:flex; align-items:flex-start; gap:12px;
  transition:box-shadow .15s, transform .15s;
}
.sdm-field-card:hover { box-shadow:0 3px 14px rgba(99,102,241,.1); transform:translateY(-1px); }
.sdm-field-icon {
  width:36px; height:36px; border-radius:9px;
  display:flex; align-items:center; justify-content:center;
  font-size:15px; flex-shrink:0;
}
.sdm-field-label {
  font-size:10px; color:#94A3B8; font-weight:700;
  text-transform:uppercase; letter-spacing:.7px; margin-bottom:4px;
}
.sdm-field-val {
  font-size:13px; font-weight:700; color:#0F172A;
  word-break:break-all;
}
.sdm-input {
  width:100%; border:1.5px solid #C7D2FE; border-radius:8px;
  padding:6px 10px; font-size:13px; font-family:inherit;
  color:#0F172A; font-weight:600; outline:none; background:#EEF2FF;
  transition:border-color .18s;
}
.sdm-input:focus { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.15); }

/* ── Section label ── */
.sdm-section-title {
  font-size:10.5px; font-weight:800; letter-spacing:1.2px;
  text-transform:uppercase; color:#6366f1;
  margin-bottom:10px; display:flex; align-items:center; gap:7px;
  padding-bottom:8px; border-bottom:2px solid #E0E7FF;
}

/* ── History table ── */
.sdm-hist-table { width:100%; border-collapse:collapse; font-size:12.5px; }
.sdm-hist-table thead th {
  background:#F8FAFC; padding:9px 12px;
  font-size:10px; font-weight:700; letter-spacing:.7px;
  text-transform:uppercase; color:#94A3B8;
  border-bottom:1px solid #E2E8F0; text-align:center;
}
.sdm-hist-table tbody td {
  padding:11px 12px; border-bottom:1px solid #F1F5F9;
  text-align:center; vertical-align:middle;
}
.sdm-hist-table tbody tr:hover { background:#F8FAFC; }
.sdm-hist-table tbody tr:last-child td { border-bottom:none; }

/* ── Spinner ── */
.sdm-spinner {
  width:14px; height:14px; border-radius:50%;
  border:2px solid #E2E8F0; border-top-color:#6366f1;
  display:inline-block; animation:sdmSpin .6s linear infinite;
}
@keyframes sdmSpin { to { transform:rotate(360deg); } }

/* ── Footer buttons ── */
.sdm-foot-btn {
  padding:9px 20px; border-radius:9px;
  font-size:13px; font-weight:600; cursor:pointer; font-family:inherit;
  display:inline-flex; align-items:center; gap:7px; border:none;
}
.sdm-foot-ghost { background:none; border:1px solid #E2E8F0; color:#64748B; }
.sdm-foot-ghost:hover { background:#F8FAFC; }
.sdm-foot-primary {
  background:linear-gradient(135deg,#6366f1,#4f46e5);
  color:#fff; box-shadow:0 4px 12px rgba(99,102,241,.3);
}
.sdm-foot-primary:hover { filter:brightness(1.08); }
.sdm-foot-danger {
  background:linear-gradient(135deg,#EF4444,#DC2626);
  color:#fff; box-shadow:0 4px 12px rgba(239,68,68,.3);
}
.sdm-foot-danger:hover { filter:brightness(1.08); }
</style>

<script>
/* =============================================================
   STAFF DETAIL MODAL v2  –  State & Helpers
   ============================================================= */
let _currentStaffId = null;
let _currentEmp     = null;
let _sdmEditMode    = false;
const _NA = '<span style="color:#94A3B8;font-size:12px;font-weight:400;">– ไม่ระบุ –</span>';

/* ── Tab switcher ── */
function sdmSwitchTab(n) {
  [1, 2].forEach(i => {
    document.getElementById(`sdmTab${i}`).classList.toggle('active', i === n);
    document.getElementById(`sdmPanel${i}`).style.display = i === n ? 'block' : 'none';
  });
  if (n === 2 && _currentStaffId) loadAttendanceHistory(_currentStaffId);
}

/* ── Edit mode toggle ── */
function toggleEditMode(isEdit) {
  _sdmEditMode = isEdit;
  if (isEdit) {
    document.getElementById('sdmEditBtn').style.display   = 'none';
    document.getElementById('sdmSaveBtn').style.display   = '';
    document.getElementById('sdmCancelBtn').style.display = '';
  } else {
    document.getElementById('sdmEditBtn').style.display   = checkPermission('edit_staff') ? '' : 'none';
    document.getElementById('sdmSaveBtn').style.display   = 'none';
    document.getElementById('sdmCancelBtn').style.display = 'none';
  }

  // Toggle view ↔ input for editable fields
  document.querySelectorAll('.sdm-view-field').forEach(el => {
    el.style.display = isEdit ? 'none' : '';
  });
  document.querySelectorAll('.sdm-edit-field').forEach(el => {
    el.style.display = isEdit ? 'block' : 'none';
  });

  if (isEdit && _currentEmp) {
    // Pre-fill inputs (values might have been enriched by API)
    document.getElementById('sdmPhoneInput').value    = document.getElementById('sdmPhone').textContent.replace('– ไม่ระบุ –','').trim();
    document.getElementById('sdmEmailInput').value    = document.getElementById('sdmEmail').textContent.replace('– ไม่ระบุ –','').trim();
    document.getElementById('sdmNicknameInput').value = document.getElementById('sdmNicknameField').textContent.replace('– ไม่ระบุ –','').trim();
  }
}

/* ── Save edits → POST /api/staff/update ── */
async function saveStaffEdit() {
  const payload = {
    id:       _currentStaffId,
    phone:    document.getElementById('sdmPhoneInput').value.trim(),
    email:    document.getElementById('sdmEmailInput').value.trim(),
    nickname: document.getElementById('sdmNicknameInput').value.trim()
  };

  const saveBtn = document.getElementById('sdmSaveBtn');
  saveBtn.innerHTML = '<span class="sdm-spinner"></span> กำลังบันทึก...';
  saveBtn.disabled  = true;

  try {
    const res = await fetch('/api/staff/update', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Accept-Charset': 'utf-8'
      },
      body: JSON.stringify(payload)
    });

    // Update UI regardless of server response (optimistic)
    const phone    = payload.phone    || '– ไม่ระบุ –';
    const email    = payload.email    || '– ไม่ระบุ –';
    const nickname = payload.nickname || '– ไม่ระบุ –';

    document.getElementById('sdmPhone').textContent         = phone;
    document.getElementById('sdmEmail').textContent         = email;
    document.getElementById('sdmNicknameField').textContent = nickname;
    document.getElementById('sdmNickname').textContent      = payload.nickname
      ? `(ชื่อเล่น: ${payload.nickname}) · ${_currentStaffId}`
      : _currentStaffId;

    toggleEditMode(false);

    if (!res.ok) {
      console.warn('POST /api/staff/update returned', res.status, '(offline save only)');
    }
  } catch (err) {
    console.warn('saveStaffEdit fetch failed (offline mode):', err);
    toggleEditMode(false);
  } finally {
    saveBtn.innerHTML = '<i class="bi bi-check2-circle"></i> บันทึก';
    saveBtn.disabled  = false;
  }
}

/* ── Open modal ── */
async function openStaffDetail(staffId) {
  _currentStaffId = staffId;
  _sdmEditMode    = false;

  const emp = employees.find(e => e.id === staffId);
  if (!emp) { console.warn('openStaffDetail: not found', staffId); return; }
  _currentEmp = emp;

  // Reset tabs to Tab 1
  sdmSwitchTab(1);
  toggleEditMode(false);

  /* Avatar */
  const colorIdx = employees.indexOf(emp) % AV_COLORS.length;
  const color    = AV_COLORS[colorIdx];
  document.getElementById('sdmAv').textContent      = emp.name ? emp.name.charAt(0) : '?';
  document.getElementById('sdmAv').style.background = color;
  document.getElementById('sdmName').textContent    = emp.name || '—';
  document.getElementById('sdmNickname').textContent = emp.id || '—';

  /* Status strip */
  const statChips = {
    'in':   '<span class="status-chip chip-in">● เข้างาน</span>',
    'out':  '<span class="status-chip chip-out">● ออกงาน</span>',
    'late': '<span class="status-chip chip-late">● มาสาย</span>',
    'leave':'<span class="status-chip" style="background:#FEF3C7;color:#D97706;border:1px solid #FCD34D;">📅 ลา</span>',
    'none': '<span class="status-chip chip-absent">● ยังไม่มา</span>',
    '':     '<span style="color:#94A3B8;font-size:12px;">—</span>'
  };
  const shiftKey   = emp.shift?.toLowerCase();
  const shiftLabel = (shiftKey && SHIFTS[shiftKey]) ? SHIFTS[shiftKey].label : (emp.shift || '—');
  const sc = { morning:'#F59E0B', afternoon:'#3B82F6', night:'#7C3AED' }[shiftKey] || '#6366F1';

  document.getElementById('sdmStatusBar').innerHTML = `
    ${statChips[emp.status || ''] || ''}
    <span style="background:${sc}1A;color:${sc};font-size:11.5px;font-weight:700;
      padding:3px 12px;border-radius:20px;border:1px solid ${sc}40;gap:5px;
      display:inline-flex;align-items:center;">
      <i class="bi bi-clock"></i> ${shiftLabel}
    </span>
    ${emp.leave_status ? `<span style="background:#FEF3C7;color:#D97706;font-size:11.5px;
      font-weight:600;padding:3px 12px;border-radius:20px;border:1px solid #FCD34D;">
      ${emp.leave_status}</span>` : ''}
  `;

  /* Static chip for tab1 */
  document.getElementById('sdmStatusBadge').innerHTML = statChips[emp.status || ''] || _NA;

  /* Known fields */
  document.getElementById('sdmId').innerHTML            = emp.id   || _NA;
  document.getElementById('sdmDept').innerHTML          = emp.dept || _NA;
  document.getElementById('sdmRole').innerHTML          = emp.role || _NA;
  document.getElementById('sdmTimeIn').innerHTML        = emp.in  ? `<span class="time-tag">${emp.in}</span>`       : _NA;
  document.getElementById('sdmTimeOut').innerHTML       = emp.out ? `<span class="time-tag out">${emp.out}</span>`   : _NA;
  document.getElementById('sdmHours').innerHTML         = (emp.hours && emp.hours !== '0')
    ? `<span style="color:#10B981;font-size:15px;">${emp.hours}</span> ชม.` : _NA;
  document.getElementById('sdmConf').innerHTML          = emp.conf > 0
    ? `<span style="color:${emp.conf>=97?'#10B981':emp.conf>=93?'#F59E0B':'#EF4444'};font-size:15px;">${emp.conf}%</span>` : _NA;

  /* Extended fields - loading state */
  ['sdmPhone','sdmEmail','sdmNicknameField','sdmStartDate'].forEach(id => {
    document.getElementById(id).innerHTML = '<span style="color:#94A3B8;font-size:11px;"><span class="sdm-spinner" style="width:10px;height:10px;"></span></span>';
  });

  /* Check Permission for Edit Button */
  const editBtn = document.getElementById('sdmEditBtn');
  if (editBtn) {
    editBtn.style.display = checkPermission('edit_staff') ? '' : 'none';
  }

  /* Show modal */
  document.getElementById('staffDetailModal').style.display = 'flex';
  document.body.style.overflow = 'hidden';

  /* Async: fetch extended profile */
  try {
    const res = await fetch(`/api/personnel/${encodeURIComponent(staffId)}`, { headers: { 'Accept-Charset': 'utf-8' } });
    if (res.ok) {
      const { person: p } = await res.json();
      if (p) {
        const nn = p.NICKNAME || '';
        document.getElementById('sdmNickname').textContent       = nn ? `(ชื่อเล่น: ${nn}) · ${emp.id}` : emp.id;
        const maskedPhone = maskSensitiveData(p.HR_PHONE, 'view_phone');
        const maskedEmail = maskSensitiveData(p.HR_EMAIL, 'view_email');

        document.getElementById('sdmNickname').textContent       = nn ? `(ชื่อเล่น: ${nn}) · ${emp.id}` : emp.id;
        document.getElementById('sdmPhone').innerHTML            = p.HR_PHONE
          ? `<a href="tel:${p.HR_PHONE}" style="color:var(--primary);font-weight:700;">${maskedPhone}</a>` : _NA;
        document.getElementById('sdmEmail').innerHTML            = p.HR_EMAIL
          ? `<a href="mailto:${p.HR_EMAIL}" style="color:#6366F1;">${maskedEmail}</a>` : _NA;
        document.getElementById('sdmNicknameField').textContent  = nn || '';
        document.getElementById('sdmNicknameField').innerHTML    = nn || _NA;
        document.getElementById('sdmStartDate').innerHTML        = p.HR_STARTWORK_DATE
          ? new Date(p.HR_STARTWORK_DATE).toLocaleDateString('th-TH',{year:'numeric',month:'long',day:'numeric'}) : _NA;
        return;
      }
    }
    _sdmFallback();
  } catch { _sdmFallback(); }
}

function _sdmFallback() {
  ['sdmPhone','sdmEmail','sdmNicknameField','sdmStartDate'].forEach(id => {
    document.getElementById(id).innerHTML = _NA;
  });
}

/* ── Close ── */
function closeStaffDetail() {
  document.getElementById('staffDetailModal').style.display = 'none';
  document.body.style.overflow = '';
  _sdmEditMode = false;
}
document.getElementById('staffDetailModal').addEventListener('click', function(e) {
  if (e.target === this) closeStaffDetail();
});

/* =============================================================
   ATTENDANCE HISTORY TABLE
   ============================================================= */
async function loadAttendanceHistory(staffId) {
  const tbody   = document.getElementById('sdmHistBody');
  const loading = document.getElementById('sdmHistoryLoading');
  loading.style.display = 'flex';
  tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:28px;color:#94A3B8;"><span class="sdm-spinner" style="width:20px;height:20px;"></span></td></tr>';

  try {
    const res = await fetch(`/api/attendance/history/${encodeURIComponent(staffId)}`, { headers: { 'Accept-Charset': 'utf-8' } });
    let historyData = null;

    if (res.ok) {
      const json = await res.json();
      historyData = json.history || [];
    } else {
      historyData = _buildHistoryFromMemory(staffId);
    }

    renderHistoryTable(historyData);
  } catch {
    renderHistoryTable(_buildHistoryFromMemory(staffId));
  } finally {
    loading.style.display = 'none';
  }
}

/* Build basic history from in-memory data for today only */
function _buildHistoryFromMemory(staffId) {
  const emp   = employees.find(e => e.id === staffId);
  const today = new Date().toISOString().split('T')[0];
  if (!emp) return [];

  const status = emp.status === 'late'  ? 'late'
               : emp.status === 'leave' ? 'leave'
               : emp.status === 'none'  ? 'absent'
               : (emp.in ? 'normal' : 'absent');

  return [{ date: today, check_in: emp.in || '-', check_out: emp.out || '-', status }];
}

/* ── renderHistoryTable(data) ── */
/*  data = [ { date, check_in, check_out, status: 'normal'|'late'|'leave'|'absent' } ]  */
function renderHistoryTable(data) {
  const tbody = document.getElementById('sdmHistBody');
  const DAY_TH = ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'];

  const statusCfg = {
    normal: { icon:'✅', label:'ปกติ',    cls:'chip-in'   },
    late:   { icon:'⚠️', label:'มาสาย',  cls:'chip-late' },
    leave:  { icon:'📅', label:'ลา',      cls:'',         style:'background:#FEF3C7;color:#D97706;border:1px solid #FCD34D;' },
    absent: { icon:'❌', label:'ขาด',     cls:'chip-absent'},
  };

  if (!data || data.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:28px;color:#94A3B8;">ไม่มีข้อมูลประวัติการเข้างาน</td></tr>';
    return;
  }

  tbody.innerHTML = data.map(row => {
    const d    = new Date(row.date);
    const dow  = isNaN(d) ? '' : DAY_TH[d.getDay()];
    const cfg  = statusCfg[row.status] || statusCfg.absent;
    const dateF= isNaN(d) ? row.date
      : d.toLocaleDateString('th-TH',{ day:'2-digit', month:'short'});

    // calc hours if valid times
    let hoursHtml = '<span style="color:#94A3B8;">—</span>';
    if (row.check_in && row.check_in !== '-' && row.check_out && row.check_out !== '-') {
      const [hi,mi] = row.check_in.split(':').map(Number);
      const [ho,mo] = row.check_out.split(':').map(Number);
      const mins    = (ho*60+mo) - (hi*60+mi);
      if (mins > 0) hoursHtml = `<span style="font-weight:700;color:#0F172A;">${(mins/60).toFixed(1)}</span>`;
    }

    const inTag  = row.check_in  && row.check_in  !== '-'
      ? `<span class="time-tag">${row.check_in}</span>`          : '<span style="color:#94A3B8;">—</span>';
    const outTag = row.check_out && row.check_out !== '-'
      ? `<span class="time-tag out">${row.check_out}</span>`      : '<span style="color:#94A3B8;">—</span>';

    const badgeStyle = cfg.cls
      ? `class="status-chip ${cfg.cls}"`
      : `class="status-chip" style="${cfg.style || ''}"`;

    return `<tr>
      <td style="font-weight:700;white-space:nowrap;">${dateF}</td>
      <td style="color:#94A3B8;font-size:11px;">${dow}</td>
      <td>${inTag}</td>
      <td>${outTag}</td>
      <td>${hoursHtml}</td>
      <td><span ${badgeStyle}>${cfg.icon} ${cfg.label}</span></td>
    </tr>`;
  }).join('');
}

/* ── Delete Staff ── */
async function deleteStaff(staffId) {
  try {
    const res = await fetch(`/api/personnel/${encodeURIComponent(staffId)}`, {
      method: 'DELETE',
      headers: { 'Accept-Charset': 'utf-8', 'Content-Type': 'application/json' }
    });
    
    if (res.ok) {
      alert('ลบบุคลากร ' + staffId + ' สำเร็จ');
      closeStaffDetail();
      // Remove from local array and refresh
      employees = employees.filter(e => e.id !== staffId);
      applyFilter();
    } else {
      alert('เกิดข้อผิดพลาด: ' + res.statusText);
    }
  } catch (err) {
    alert('ไม่สามารถลบได้: ' + err.message);
  }
}
</script>

