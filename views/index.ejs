  background: var(--primary);
  color: #fff;
  width: 20px; height: 20px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.sm-day.morning  { background:#FFFBEB; border-color:#FDE68A; }
.sm-day.afternoon{ background:#EFF6FF; border-color:#BFDBFE; }
.sm-day.night    { background:#F5F3FF; border-color:#DDD6FE; }
.sm-day.leave    { background:#FEF3C7; border-color:#FCD34D; }
.sm-day.weekend  { background:#FAFAFA; }
.sm-shift-tag {
  font-size: 9.5px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 6px;
  display: inline-block;
  line-height: 1.5;
}
.sm-time {
  font-size: 9px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 2px;
}
.sm-dow-header {
  text-align: center;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .5px;
  text-transform: uppercase;
  color: var(--muted);
  padding: 4px 0;
}
</style>

<script>
/* =============================================================
   STAFF MODAL — State
   ============================================================= */
let _smStaffId  = null;
let _smYear     = null;
let _smMonth    = null;
let _smEmployee = null;

const DAY_NAMES = ['อา','จ','อ','พ','พฤ','ศ','ส'];
const MONTH_TH  = ['','มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];

/* Open modal for a given staff ID */
function viewStaff(id) {
  const emp = employees.find(e => e.id === id);
  if (!emp) return;

  _smEmployee = emp;
  _smStaffId  = id;
  const now   = new Date();
  _smYear  = now.getFullYear();
  _smMonth = now.getMonth() + 1;

  // Header
  const colorIdx = employees.indexOf(emp) % AV_COLORS.length;
  const color    = AV_COLORS[colorIdx];
  const init     = emp.name ? emp.name.charAt(0) : '?';

  document.getElementById('smAv').textContent   = init;
  document.getElementById('smAv').style.background = color;
  document.getElementById('smName').textContent = emp.name || '—';
  document.getElementById('smMeta').textContent = `${emp.id || ''} • ${emp.dept || ''}`;

  // Status chips
  const stat = emp.status || '';
  const statMap = {
    'in':    '<span class="status-chip chip-in">เข้างาน</span>',
    'out':   '<span class="status-chip chip-out">ออกงาน</span>',
    'late':  '<span class="status-chip chip-late">มาสาย</span>',
    'leave': '<span class="status-chip" style="background:#FEF3C7;color:#D97706;border:1px solid #FCD34D;">ลา</span>',
    'none':  '<span class="status-chip chip-absent">ยังไม่มา</span>',
    '':      '<span style="color:var(--muted);font-size:12px;">—</span>'
  };
  const shiftKey = emp.shift?.toLowerCase();
  const shiftLabel = (shiftKey && SHIFTS[shiftKey]) ? SHIFTS[shiftKey].label : (emp.shift || '—');

  document.getElementById('smChips').innerHTML = `
    <span style="font-size:12px;font-weight:600;color:var(--muted);"><i class="bi bi-person-badge"></i> ${emp.role || '—'}</span>
    <span style="color:var(--border);">|</span>
    <span style="font-size:12px;color:var(--muted);"><i class="bi bi-building"></i> ${emp.dept || '—'}</span>
    <span style="color:var(--border);">|</span>
    <span style="font-size:12px;color:var(--muted);"><i class="bi bi-clock"></i> ${shiftLabel}</span>
    <span style="color:var(--border);">|</span>
    ${statMap[stat] || stat}
    ${ emp.in  ? `<span class="time-tag" style="margin-left:4px;"><i class="bi bi-box-arrow-in-right"></i> ${emp.in}</span>`  : '' }
    ${ emp.out ? `<span class="time-tag out"><i class="bi bi-box-arrow-right"></i> ${emp.out}</span>` : '' }
    ${ emp.hours && emp.hours !== '0' ? `<span class="status-chip chip-in" style="margin-left:4px;"><i class="bi bi-hourglass-split"></i> ${emp.hours} ชม.</span>` : '' }
  `;

  // Show modal
  const modal = document.getElementById('staffModal');
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';

  // Render calendar
  renderStaffCalendar(_smStaffId, _smYear, _smMonth);
}

function closeStaffModal() {
  document.getElementById('staffModal').style.display = 'none';
  document.body.style.overflow = '';
}

// Close on backdrop
document.getElementById('staffModal').addEventListener('click', function(e) {
  if (e.target === this) closeStaffModal();
});

/* Navigate month inside modal */
function smChangeMonth(delta) {
  _smMonth += delta;
  if (_smMonth > 12) { _smMonth = 1;  _smYear++; }
  if (_smMonth < 1)  { _smMonth = 12; _smYear--; }
  renderStaffCalendar(_smStaffId, _smYear, _smMonth);
}

/* =============================================================
   RENDER STAFF CALENDAR
   ============================================================= */
async function renderStaffCalendar(staffId, year, month) {
  const cal  = document.getElementById('smCalendar');
  const title = document.getElementById('smCalTitle');
  if (!cal) return;

  title.textContent = `${MONTH_TH[month]} ${year + 543}`;
  cal.innerHTML = `
    <div style="grid-column:1/-1;display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:4px;">
      ${DAY_NAMES.map(d => `<div class="sm-dow-header">${d}</div>`).join('')}
    </div>`;

  const daysInMonth = new Date(year, month, 0).getDate();
  const firstDow    = new Date(year, month - 1, 1).getDay(); // 0=Sun
  const todayStr    = new Date().toISOString().split('T')[0];
  const settings    = loadSettings();

  // ── Fetch shift schedule for this staff member & month ──
  let shiftMap  = {}; // { day: shiftName }
  let leaveDays = {}; // { day: true }
  let timesMap  = {}; // { day: { in, out } }

  try {
    const yearMonth = `${year}-${String(month).padStart(2,'0')}`;
    const res = await fetch(`/api/schedule/staff/${encodeURIComponent(staffId)}/${yearMonth}`, { headers: { 'Accept-Charset': 'utf-8' } });
    if (res.ok) {
      const data = await res.json();
      (data.shifts  || []).forEach(s => { shiftMap[s.day]  = s.shift; });
      (data.leaves  || []).forEach(l => { leaveDays[l.day] = true; });
      (data.times   || []).forEach(t => { timesMap[t.day]  = { in: t.time_in, out: t.time_out }; });
    }
  } catch (err) {
    // Fallback: use data we already have in-memory
    // Check serviceWorkData for today
    const todayDay = new Date().getDate();
    if (month === (new Date().getMonth() + 1) && year === new Date().getFullYear()) {
      const sw = serviceWorkData.find(s => s.name === _smEmployee?.name);
      if (sw) {
        const isLeave = (sw.morning  && !/^\d{2}:\d{2}/.test(sw.morning))
                     || (sw.afternoon && !/^\d{2}:\d{2}/.test(sw.afternoon));
        if (isLeave) leaveDays[todayDay] = true;
      }
      // Time from employee object
      if (_smEmployee?.in) timesMap[todayDay] = { in: _smEmployee.in, out: _smEmployee.out };
    }
  }

  // Shift display config (from settings)
  const shiftStyleMap = {};
  (settings.shifts || []).forEach(sh => {
    if (sh.name === 'เช้า')  shiftStyleMap[sh.name] = { cls: 'morning',   tag: 'morning-tag',   color: sh.color || '#F59E0B', bg: '#FFFBEB', tc: '#92400E' };
    else if (sh.name === 'บ่าย') shiftStyleMap[sh.name] = { cls: 'afternoon', tag: 'afternoon-tag', color: sh.color || '#3B82F6', bg: '#EFF6FF', tc: '#1E40AF' };
    else if (sh.name === 'ดึก')  shiftStyleMap[sh.name] = { cls: 'night',     tag: 'night-tag',     color: sh.color || '#7C3AED', bg: '#F5F3FF', tc: '#5B21B6' };
    else shiftStyleMap[sh.name] = { cls: '', color: sh.color || '#6366F1', bg: '#EEF2FF', tc: '#4F46E5' };
  });

  // ── Build inner grid ──
  let html = '';

  // Blank cells before 1st of month
  for (let b = 0; b < firstDow; b++) {
    html += `<div style="min-height:72px;"></div>`;
  }

  for (let d = 1; d <= daysInMonth; d++) {
    const date    = new Date(year, month - 1, d);
    const dow     = date.getDay();
    const dateStr = `${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday   = dateStr === todayStr;
    const isWeekend = (dow === 0 || dow === 6);
    const isLeave   = leaveDays[d];
    const shift     = shiftMap[d];
    const times     = timesMap[d];

    // Determine cell style
    let cellCls = isLeave ? 'leave' : (shift && shiftStyleMap[shift] ? shiftStyleMap[shift].cls : (isWeekend ? 'weekend' : ''));
    if (isToday) cellCls += ' today';

    // Shift tag
    let shiftHtml = '';
    if (isLeave) {
      shiftHtml = `<span class="sm-shift-tag" style="background:#FEF3C7;color:#D97706;">ลา</span>`;
    } else if (shift && shiftStyleMap[shift]) {
      const st = shiftStyleMap[shift];
      shiftHtml = `<span class="sm-shift-tag" style="background:${st.bg};color:${st.tc};">${shift}</span>`;
    } else if (shift) {
      shiftHtml = `<span class="sm-shift-tag" style="background:#EEF2FF;color:#4F46E5;">${shift}</span>`;
    } else {
      shiftHtml = `<span style="font-size:9px;color:#CBD5E1;">OFF</span>`;
    }

    // Time tags
    let timeHtml = '';
    if (times?.in) {
      timeHtml += `<div class="sm-time"><i class="bi bi-box-arrow-in-right" style="color:#10B981;"></i>${times.in.substring(0,5)}</div>`;
    }
    if (times?.out && times.out !== times.in) {
      timeHtml += `<div class="sm-time"><i class="bi bi-box-arrow-right" style="color:#EF4444;"></i>${times.out.substring(0,5)}</div>`;
    }

    html += `<div class="sm-day ${cellCls}">
      <div class="sm-day-num">${d}</div>
      ${shiftHtml}
      ${timeHtml}
    </div>`;
  }

  // Append to inner container
  cal.innerHTML += `<div style="display:contents;">${html}</div>`;
}
</script>

