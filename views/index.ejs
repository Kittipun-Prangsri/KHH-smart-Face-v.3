.shift-row {
  display:grid; grid-template-columns:1fr 130px 130px 36px;
  gap:8px; align-items:center; background:var(--surface,#F8FAFC);
  border-radius:10px; padding:12px 14px; margin-bottom:8px;
  border:1px solid var(--border,#E2E8F0);
}
</style>

<script>
  /* =====================================================
     SETTINGS  —  state & helpers
     ===================================================== */
  const SETTINGS_KEY = 'hospital_settings';

  const DEFAULT_SETTINGS = {
    workStart: '08:00', workEnd: '16:00', lateMin: 31,
    workDays: ['mon','tue','wed','thu','fri'],
    autoReport: 'daily',
    staffHours: {
      doctor:  { start:'08:00', end:'16:00', ot:8 },
      nurse:   { start:'07:00', end:'15:00', ot:8 },
      staff:   { start:'08:00', end:'16:00', ot:8 },
      support: { start:'08:00', end:'16:00', ot:8 }
    },
    shifts: [
      { name:'เช้า',  start:'08:00', end:'16:00', color:'#F59E0B' },
      { name:'บ่าย',  start:'16:00', end:'24:00', color:'#3B82F6' },
      { name:'ดึก',   start:'00:00', end:'08:00', color:'#7C3AED' }
    ]
  };

  function loadSettings() {
    try { return JSON.parse(localStorage.getItem(SETTINGS_KEY)) || DEFAULT_SETTINGS; }
    catch { return DEFAULT_SETTINGS; }
  }

  function openSettings() {
    const s = loadSettings();
    // Tab 1
    document.getElementById('s-work-start').value  = s.workStart;
    document.getElementById('s-work-end').value    = s.workEnd;
    document.getElementById('s-late-min').value    = s.lateMin;
    document.getElementById('s-auto-report').value = s.autoReport;
    ['sun','mon','tue','wed','thu','fri','sat'].forEach(d => {
      const el = document.getElementById('s-day-' + d);
      if (el) el.checked = s.workDays.includes(d);
    });
    // Tab 2
    ['doctor','nurse','staff','support'].forEach(t => {
      const h = s.staffHours[t] || {};
      if (document.getElementById('s-' + t + '-start'))
        document.getElementById('s-' + t + '-start').value = h.start || '08:00';
      if (document.getElementById('s-' + t + '-end'))
        document.getElementById('s-' + t + '-end').value = h.end || '16:00';
      if (document.getElementById('s-' + t + '-ot'))
        document.getElementById('s-' + t + '-ot').value = h.ot || 8;
    });
    // Tab 3 — render shift rows
    renderShiftList(s.shifts);
    switchSettingsTab(1);
    const modal = document.getElementById('settingsModal');
    modal.style.display = 'flex';
  }

  function closeSettings() {
    document.getElementById('settingsModal').style.display = 'none';
  }

  function switchSettingsTab(n) {
    [1,2,3].forEach(i => {
      document.getElementById('stab-' + i).classList.toggle('active', i === n);
      document.getElementById('spanel-' + i).style.display = i === n ? 'block' : 'none';
    });
  }

  /* --- Shift rows --- */
  let _shifts = [];

  function renderShiftList(shifts) {
    _shifts = shifts ? JSON.parse(JSON.stringify(shifts)) : [];
    const el = document.getElementById('shiftList');
    el.innerHTML = _shifts.map((sh, i) => `
      <div class="shift-row">
        <input type="text" class="sinput" value="${sh.name}" placeholder="ชื่อเวร"
          onchange="_shifts[${i}].name=this.value" style="min-width:0;">
        <input type="time" class="sinput" value="${sh.start}"
          onchange="_shifts[${i}].start=this.value">
        <input type="time" class="sinput" value="${sh.end}"
          onchange="_shifts[${i}].end=this.value">
        <button onclick="removeShift(${i})" style="border:none;background:#FEE2E2;color:#EF4444;border-radius:7px;width:34px;height:34px;cursor:pointer;font-size:16px;">✕</button>
      </div>
    `).join('');
  }

  function addShift() {
    _shifts.push({ name:'เวรใหม่', start:'00:00', end:'08:00', color:'#6366F1' });
    renderShiftList(_shifts);
  }

  function removeShift(i) {
    _shifts.splice(i, 1);
    renderShiftList(_shifts);
  }

  function saveSettings() {
    const days = ['sun','mon','tue','wed','thu','fri','sat'].filter(d => {
      const el = document.getElementById('s-day-' + d);
      return el && el.checked;
    });
    const staffHours = {};
    ['doctor','nurse','staff','support'].forEach(t => {
      staffHours[t] = {
        start: document.getElementById('s-' + t + '-start')?.value || '08:00',
        end:   document.getElementById('s-' + t + '-end')?.value   || '16:00',
        ot:    parseInt(document.getElementById('s-' + t + '-ot')?.value || 8)
      };
    });
    const settings = {
      workStart:   document.getElementById('s-work-start').value,
      workEnd:     document.getElementById('s-work-end').value,
      lateMin:     parseInt(document.getElementById('s-late-min').value),
      workDays:    days,
      autoReport:  document.getElementById('s-auto-report').value,
      staffHours,
      shifts:      _shifts
    };
    localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings));

    // Flash save button
    const btn = event.currentTarget;
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="bi bi-check-lg"></i> บันทึกแล้ว!';
    btn.style.background = 'linear-gradient(135deg,#10B981,#059669)';
    setTimeout(() => {
      btn.innerHTML = orig;
      btn.style.background = 'linear-gradient(135deg,#6366F1,#8B5CF6)';
      closeSettings();
    }, 1200);
  }

  // Close on backdrop click
  document.getElementById('settingsModal').addEventListener('click', function(e) {
    if (e.target === this) closeSettings();
  });

  init();
</script>

